{
  "extends": "astro/tsconfigs/strictest",
  "compilerOptions": {
    "allowJs": false,
    "baseUrl": ".",
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["astro/client"]
  },
  "include": [".astro/types.d.ts", "src/**/*", "tests/**/*", "astro.config.mjs"],
  "exclude": ["dist", "legacy-next-src", "node_modules", "src/worker.ts"]
}
