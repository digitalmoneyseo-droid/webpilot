# Build-time public configuration. Concept mode is the safe default.
PUBLIC_SITE_URL=https://webpilot.studio
PUBLIC_SITE_MODE=concept
PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN=
CONTACT_FORM_ENABLED=false
CONTACT_RECIPIENT=hello@webpilot.studio
CONTACT_SENDER=website@webpilot.studio

# Live-mode legal operator data. All required fields must be real before launch.
LEGAL_NAME=
LEGAL_STREET_ADDRESS=
LEGAL_POSTAL_CODE=
LEGAL_CITY=
LEGAL_COUNTRY=Deutschland
LEGAL_REPRESENTATIVE=
LEGAL_EMAIL=
LEGAL_REGISTER_NAME=
LEGAL_REGISTER_NUMBER=
LEGAL_VAT_ID=

# Runtime secrets: put these in .dev.vars locally and Cloudflare secrets remotely.
TURNSTILE_SECRET_KEY=
RESEND_API_KEY=
