---
import BaseLayout from "@/layouts/BaseLayout.astro";
---
<BaseLayout locale="de" title="404" description="Die angeforderte Seite wurde nicht gefunden." indexable={false}>
  <main id="main-content" class="not-found flex min-h-screen flex-col items-center justify-center px-page py-section text-center"><span class="font-mono text-caption">404</span><h1 class="m-6 text-display-sm font-semibold">Dieses Signal ging verloren.</h1><p class="text-body leading-body text-[#777]">Die angeforderte Seite existiert nicht oder wurde verschoben.<br />The page you’re looking for does not exist or has moved.</p><div class="hero-actions mt-8 flex gap-3 max-[600px]:w-[min(270px,100%)] max-[600px]:flex-col max-[600px]:items-stretch"><a class="pill-button min-h-11 rounded-xl bg-[#111] px-[17px] py-3 text-small text-white" href="/">Zurück zum Studio</a><a class="pill-button pill-button--light min-h-11 rounded-xl bg-[#111] px-[17px] py-3 text-small text-white" href="/en">Back to the studio</a></div></main>
</BaseLayout>
