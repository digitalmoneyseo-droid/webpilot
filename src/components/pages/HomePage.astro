---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BenefitIcon from "@/components/BenefitIcon.astro";
import CtaButton from "@/components/CtaButton.astro";
import Faq from "@/components/Faq.astro";
import FinalCta from "@/components/FinalCta.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import Reveal from "@/components/Reveal.astro";
import ServiceSymbol from "@/components/ServiceSymbol.astro";
import ServiceCategoryGrid from "@/components/ServiceCategoryGrid.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import { PencilRuler, Rocket, ScanSearch } from "@lucide/astro";
import { getFaqs, getProjects, getServices, getTestimonials } from "@/lib/content";
import { localizePath, t, type Locale } from "@/lib/i18n";
import { localizedPillarDescription, localizedPillarTitle, servicePillars } from "@/lib/services";

interface Props { locale: Locale; }
const { locale } = Astro.props;
const heroWords = locale === "de"
  ? [
      { text: "Wir" },
      { text: "helfen" },
      { text: "starken", emphasis: true },
      { text: "Marken" },
      { text: "beim" },
      { text: "Wachstum." },
    ]
  : [
      { text: "We" },
      { text: "help" },
      { text: "bold", emphasis: true },
      { text: "brands" },
      { text: "grow." },
    ];
const heroTitle = heroWords.map(({ text }) => text).join(" ");
let heroLetterIndex = 0;
const heroSegments = heroWords.map((word) => {
  const letters = Array.from(word.text, (text) => ({ text, index: heroLetterIndex++ }));
  heroLetterIndex += 1;
  return { ...word, letters };
});
const [projects, services, testimonials, faqs] = await Promise.all([getProjects(locale), getServices(locale), getTestimonials(locale), getFaqs(locale)]);
const benefits = [
  ["outcome", "Results first", "Good work must also create demand, win sales, or save time."],
  ["senior", "Senior specialists only", "You work directly with experienced strategists, designers, developers, marketers, and automation specialists."],
  ["system", "Plan through launch", "One team plans and runs your brand, tech, marketing, content, and automation."],
  ["ownership", "One responsible partner", "One senior team owns the plan, work, updates, and results from start to end."],
  ["creative-tech", "Design and tech together", "We plan brand, content, code, data, and AI together."],
] as const;
const processSteps = [
  { icon: ScanSearch, title: "Define", copy: "Goals, users, positioning and scope." },
  { icon: PencilRuler, title: "Create", copy: "Design, build and integrate." },
  { icon: Rocket, title: "Launch and improve", copy: "Test, release and optimise." },
] as const;
const description = t(locale, "Branding, websites, apps, SEO, AI search, content, paid acquisition, analytics, and intelligent automation—all delivered by one senior team.");
---
<BaseLayout {locale} {description}>
  <main id="main-content">
    <section class="hero hero--home grid min-h-[34rem] grid-cols-1 [place-items:start_center] px-page pt-32 pb-16 max-[600px]:min-h-0 max-[600px]:px-[18px] max-[600px]:pt-[6.5rem] max-[600px]:pb-12"><div class="hero-inner flex w-full min-w-0 max-w-[58rem] flex-col items-center text-center"><h1 class="mt-6 mb-6 w-full max-w-hero text-display-lg font-bold max-[600px]:max-w-full max-[600px]:text-[30px] max-[600px]:leading-[1.06] max-[600px]:tracking-[-.045em]" aria-label={heroTitle}><span class="shiny-text inline-block" aria-hidden="true">{heroSegments.map((word, wordIndex) => <>{word.emphasis ? <em class="hero-word-group inline-block whitespace-nowrap">{word.letters.map((letter) => <span class="hero-letter-mask inline-block align-bottom"><span class="hero-letter inline-block" style={`--letter-index:${letter.index}`}>{letter.text}</span></span>)}</em> : <span class="hero-word-group inline-block whitespace-nowrap">{word.letters.map((letter) => <span class="hero-letter-mask inline-block align-bottom"><span class="hero-letter inline-block" style={`--letter-index:${letter.index}`}>{letter.text}</span></span>)}</span>}{wordIndex < heroSegments.length - 1 && " "}</>)}</span></h1><p class="hero-copy m-0 w-full max-w-narrow text-lead leading-[1.55] max-[600px]:max-w-[350px] max-[600px]:text-sm">{description}</p><div class="hero-actions mt-8 flex gap-3 max-[600px]:w-[min(270px,100%)] max-[600px]:flex-col max-[600px]:items-stretch max-[600px]:justify-center"><CtaButton href={localizePath("/contact", locale)} class="cta-beacon">{t(locale, "Book strategy call")}</CtaButton><CtaButton href={localizePath("/work", locale)} light class="cta-shake">{t(locale, "Explore our work")}</CtaButton></div></div></section>

    <section class="work-ribbon overflow-hidden px-6 pt-2 pb-[54px] max-[900px]:px-0 max-[600px]:px-0 max-[600px]:pt-2 max-[600px]:pb-[38px]" aria-label={t(locale, "Selected work")}><div class="work-ribbon-track flex w-max will-change-transform"><div class="work-ribbon-group flex flex-none">{projects.map(({ data }) => <ProjectCard project={data} {locale} />)}</div><div class="work-ribbon-group flex flex-none" aria-hidden="true">{projects.map(({ data }) => <ProjectCard project={data} {locale} decorative />)}</div></div></section>

    <section class="why-section px-page pt-[90px] pb-section"><SectionHeading title={t(locale, "Why Webpilot")} align="center" /><div class="benefit-grid grid grid-cols-6 gap-4 max-[900px]:grid-cols-2 max-[600px]:grid-cols-1">{benefits.map(([icon, title, copy], index) => <Reveal class={`benefit-card benefit-card-${index + 1} col-span-2 px-6 pt-3 pb-6 text-center max-[900px]:col-auto`} delay={index * 50}><div class="benefit-visual grid place-items-center text-ink [&_svg]:size-[42px]"><BenefitIcon name={icon} /></div><h3 class="mt-6 mb-2 text-heading-sm font-semibold">{t(locale, title)}</h3><p class="m-0 text-body leading-body text-muted">{t(locale, copy)}</p></Reveal>)}</div></section>

    <section class="service-section bg-dark px-page py-section text-inverse">
      <SectionHeading title={t(locale, "Build. Grow. Automate.")} copy={t(locale, "We cover many skills but judge all work by one thing: your business result.")} />
      <div class="service-trio grid grid-cols-3 gap-4 max-[900px]:grid-cols-2 max-[600px]:grid-cols-1">
        {servicePillars.map((pillar) => <article class={`service-card service-card--${pillar.id} relative flex min-h-96 flex-col overflow-hidden rounded-card border-0 bg-[#151515] p-6 shadow-dark-surface max-[600px]:min-h-[22rem]`}>
            <ServiceSymbol name={pillar.symbol} />
            <h3>{localizedPillarTitle(pillar, locale)}</h3>
            <p>{localizedPillarDescription(pillar, locale)}</p>
          </article>)}
      </div>
    </section>

    <section class="service-category-section px-page py-section"><SectionHeading title={locale === "de" ? "Konkrete Expertise. Klar organisiert." : "Concrete expertise. Clearly organised."} copy={locale === "de" ? "Vier Leistungsbereiche, die einzeln funktionieren und gemeinsam stärker werden." : "Four service categories that work independently and become stronger together."} /><ServiceCategoryGrid {services} {locale} compact /></section>

    <section class="engagement-section process-section px-page py-section">
      <SectionHeading title={t(locale, "From first idea to launch.")} copy={t(locale, "A clear shared plan keeps design, tech, and delivery in step.")} />
      <ol class="process-list mx-auto my-0 grid w-full max-w-[62rem] list-none grid-cols-3 items-stretch gap-4 px-0 pt-[52px] max-[900px]:grid-cols-1 max-[900px]:gap-[52px] max-[900px]:pt-0 max-[900px]:pr-[18px] max-[900px]:pl-14" data-reveal data-mobile-reveal-items>
        {processSteps.map(({ icon: StepIcon, title, copy }, index) => <li class="process-step relative min-h-0 rounded-card bg-surface p-6 shadow-surface" style={`--process-delay:${index * 350}ms`}>
          <span class="process-node absolute -top-[52px] left-[calc(50%_-_19px)] z-2 grid size-[38px] place-items-center rounded-full bg-[#111] text-[15px] leading-none font-semibold text-white max-[900px]:top-3.5 max-[900px]:-left-[57px]" aria-hidden="true">{index + 1}</span>
          <div class="process-marker grid size-[42px] place-items-center [&_svg]:size-[42px]"><StepIcon aria-hidden="true" /></div>
          <div class="process-copy pt-7"><h3 class="mt-0 mb-2 text-heading-sm font-semibold">{t(locale, title)}</h3><p class="m-0 max-w-[34ch] text-body leading-body text-muted">{t(locale, copy)}</p></div>
        </li>)}
      </ol>
    </section>

    <section class="testimonial-section px-page py-section"><SectionHeading title={t(locale, "Testimonials")} align="center" /><div class="testimonial-grid mx-auto grid max-w-[1080px] grid-cols-3 gap-4 max-[600px]:grid-cols-1">{testimonials.slice(0, 3).map(({ data }, index) => <Reveal class="testimonial-card flex min-h-[270px] flex-col rounded-card bg-surface p-6 shadow-surface" delay={(index % 3) * 50}><span class="text-caption font-extrabold tracking-[-.04em]">{data.brand}</span><blockquote class="mx-0 mt-10 mb-6 text-body leading-body">“{data.quote}”</blockquote><small class="mt-auto text-small font-semibold">{data.attribution}</small><i class="mt-1 text-caption not-italic text-[#70706d]">{locale === "de" ? "Kundenstimme" : "Client testimonial"}</i></Reveal>)}</div></section>

    <section class="faq-section bg-canvas px-page py-section"><SectionHeading title="FAQs" align="center" /><div class="faq-layout mx-auto block max-w-[820px]"><Faq items={faqs} id={`home-faq-${locale}`} /></div></section><FinalCta {locale} />
  </main>
</BaseLayout>
