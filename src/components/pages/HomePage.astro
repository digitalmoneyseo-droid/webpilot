---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BenefitIcon from "@/components/BenefitIcon.astro";
import CtaButton from "@/components/CtaButton.astro";
import Faq from "@/components/Faq.astro";
import FinalCta from "@/components/FinalCta.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import Reveal from "@/components/Reveal.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import TextLink from "@/components/TextLink.astro";
import ToolLogo from "@/components/ToolLogo.astro";
import { getFaqs, getProjects, getTeam, getTestimonials } from "@/lib/content";
import { localizePath, t, type Locale } from "@/lib/i18n";

interface Props { locale: Locale; }
const { locale } = Astro.props;
const [projects, team, testimonials, faqs] = await Promise.all([getProjects(locale), getTeam(locale), getTestimonials(locale), getFaqs(locale)]);
const benefits = [
  ["outcome", "Outcome obsessed", "Beautiful work is only the beginning. Every engagement is tied to qualified demand, conversion, pipeline, or efficiency."],
  ["senior", "Senior specialists only", "You work directly with experienced strategists, designers, developers, marketers, and automation specialists."],
  ["system", "Strategy through execution", "Positioning, creative, technology, acquisition, content, and automation work as one coordinated system."],
  ["ownership", "One accountable partner", "One senior team owns the strategy, delivery, communication, and performance from end to end."],
  ["creative-tech", "Creative and technology together", "Brand, content, code, data, and AI are planned together—not managed as disconnected silos."],
] as const;
const tools = ["Figma", "Framer", "Webflow", "Astro", "TypeScript", "Tailwind CSS", "Shopify", "WordPress", "After Effects", "Rive", "Lottie", "OpenAI", "Make", "n8n"];
const description = t(locale, "Brand, web, SEO, AI search, content, paid acquisition, and intelligent automation—all delivered by one senior team.");
---
<BaseLayout {locale} {description}>
  <main id="main-content">
    <section class="hero hero--home"><div class="hero-inner"><h1><span class="shiny-text">{t(locale, "We build growth systems for ambitious brands.")}</span></h1><p>{description}</p><div class="hero-actions"><CtaButton href={localizePath("/contact", locale)}>{t(locale, "Book strategy call")}</CtaButton><CtaButton href={localizePath("/work", locale)} light>{t(locale, "Explore our work")}</CtaButton></div></div></section>

    <section class="work-ribbon" aria-label={t(locale, "Selected work")}><div class="work-ribbon-track"><div class="work-ribbon-group">{projects.map(({ data }) => <ProjectCard project={data} {locale} />)}</div><div class="work-ribbon-group" aria-hidden="true">{projects.map(({ data }) => <ProjectCard project={data} {locale} decorative />)}</div></div></section>

    <section class="logo-cloud"><h2>{locale === "de" ? "Fiktive Marken zur Veranschaulichung des Systems." : "Fictional brands created to demonstrate the system."}</h2><div class="logo-row"><span>VERDANT</span><span>North/Co</span><span>orbit*</span><span>MORROW</span><span>Arc Labs</span><span>KINDRED</span><span>FORM</span><span>+ 20 more</span></div></section>

    <section class="why-section section-pad"><SectionHeading title={t(locale, "Why Webpilot")} align="center" /><div class="benefit-grid">{benefits.map(([icon, title, copy], index) => <Reveal class={`benefit-card benefit-card-${index + 1}`} delay={index * 50}><div class="benefit-visual"><BenefitIcon name={icon} /></div><h3>{t(locale, title)}</h3><p>{t(locale, copy)}</p></Reveal>)}</div></section>

    <section class="service-section section-pad"><SectionHeading eyebrow={t(locale, "One coordinated system")} title={t(locale, "Build. Grow. Automate.")} copy={t(locale, "The studio model is intentionally broad at the edges and tightly connected at the center: your commercial outcome.")} /><div class="service-trio">{([
      ["Build", "We create distinctive brands, high-converting websites, and digital products designed for long-term growth.", "brand-web-product", "01"],
      ["Grow", "We increase visibility and demand through SEO, AI search, content, paid acquisition, and conversion optimization.", "seo-ai-search", "02"],
      ["Automate", "We build AI agents, workflow automations, CRM systems, and intelligent tools that reduce manual work.", "ai-automation", "03"],
    ] as const).map(([title, copy, slug, number]) => <a href={localizePath(`/services/${slug}`, locale)} class="service-card"><span>{number}</span><div class={`service-symbol symbol-${title.toLowerCase()}`}><i></i><i></i><i></i></div><h3>{t(locale, title)}</h3><p>{t(locale, copy)}</p><b>{t(locale, "Explore service")} ↗</b></a>)}</div></section>

    <section class="results-section section-pad"><div class="results-intro"><SectionHeading eyebrow={t(locale, "Selected outcomes")} title={t(locale, "Work that earns its place on the dashboard.")} copy={locale === "de" ? "Alle Ergebnisse sind fiktive Konzeptdaten und werden vor einer Live-Veröffentlichung durch verifizierte Kundendaten ersetzt." : "Every result is fictional concept data and will be replaced by verified client reporting before a live release."} /><TextLink href={localizePath("/work", locale)}>{t(locale, "See all case studies")}</TextLink></div><div class="metrics-grid">{projects.slice(0, 4).map(({ data }, index) => <Reveal class="metric-card" delay={index * 70}><span>{locale === "de" ? "Konzept-Ergebnis" : "Concept result"}</span><strong>{data.metric}</strong><h3>{data.metricLabel}</h3><a href={localizePath(`/work/${data.slug}`, locale)}>{data.shortTitle} ↗</a></Reveal>)}</div></section>

    <section class="search-section section-pad"><div class="search-art" aria-hidden="true"><div class="search-orbit"><i></i><i></i><i></i><span>?</span></div><div class="answer-chip chip-a">Google</div><div class="answer-chip chip-b">ChatGPT</div><div class="answer-chip chip-c">Gemini</div><div class="answer-chip chip-d">Perplexity</div><div class="search-pulse"></div></div><div class="search-copy"><span class="eyebrow">SEO + GEO</span><h2>{t(locale, "Be visible wherever your customers search.")}</h2><p>{t(locale, "We improve visibility across traditional search engines and AI-generated answers through technical SEO, content strategy, entity optimization, structured data, authority building, and Generative Engine Optimization.")}</p><div class="mini-tags"><span>Google</span><span>Bing</span><span>ChatGPT</span><span>Gemini</span><span>Perplexity</span><span>AI Overviews</span></div><CtaButton href={localizePath("/services/seo-ai-search", locale)}>{t(locale, "Explore SEO & AI search")}</CtaButton></div></section>

    <section class="testimonial-section section-pad"><SectionHeading title={t(locale, "Testimonials")} align="center" /><div class="testimonial-grid">{testimonials.map(({ data }, index) => <Reveal class="testimonial-card" delay={(index % 3) * 50}><span>{data.brand}</span><blockquote>“{data.quote}”</blockquote><small>{data.attribution}</small><i>{locale === "de" ? "Konzept-Kundenstimme" : "Concept testimonial"}</i></Reveal>)}</div></section>

    <section class="tools-section section-pad"><SectionHeading title={t(locale, "Tools we’ve mastered")} align="center" /><div class="tools-marquee"><div class="tools-marquee-track">{[0, 1].map((group) => <div class="tools-marquee-group" aria-hidden={group === 1 ? "true" : undefined}>{tools.map((tool) => <span><ToolLogo name={tool} />{tool}</span>)}</div>)}</div></div></section>

    <section class="team-section section-pad"><SectionHeading title={locale === "de" ? "Konzept-Team · Nah an der Arbeit." : "Concept team · Close to the work."} align="center" /><div class="team-grid">{team.map(({ data }, index) => <Reveal class="team-card" delay={(index % 5) * 40}><div class={`team-portrait portrait-${(index % 5) + 1}`}><span>{data.initials}</span><i></i></div><h3>{data.name}</h3><p>{data.role}</p></Reveal>)}</div></section>

    <section class="engagement-section section-pad"><SectionHeading eyebrow={t(locale, "Ways to work together")} title={t(locale, "The right shape for the problem.")} /><div class="engagement-list">{([
      ["Projects", "Branding, websites, product design, development, AI implementations, and automation systems."],
      ["Growth retainers", "SEO, content, social media, paid acquisition, analytics, and conversion optimization."],
      ["Embedded growth team", "A multidisciplinary monthly team across strategy, creative, technology, acquisition, content, data, and AI."],
      ["Audits & strategy", "Focused growth, search, analytics, conversion, AI-readiness, and automation discovery."],
    ] as const).map(([title, copy], index) => <div><span>0{index + 1}</span><h3>{t(locale, title)}</h3><p>{t(locale, copy)}</p></div>)}</div></section>

    <section class="faq-section section-pad"><div class="faq-layout"><SectionHeading eyebrow={t(locale, "Good to know")} title="FAQs" /><Faq items={faqs} id={`home-faq-${locale}`} /></div></section><FinalCta {locale} />
  </main>
</BaseLayout>
