---
import BaseLayout from "@/layouts/BaseLayout.astro";
import EditorialHero from "@/components/EditorialHero.astro";
import Faq from "@/components/Faq.astro";
import FinalCta from "@/components/FinalCta.astro";
import NumberedList from "@/components/NumberedList.astro";
import RelatedWork from "@/components/RelatedWork.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import type { ProjectEntry, ServiceEntry } from "@/lib/content";
import type { Locale } from "@/lib/i18n";
interface Props {
  locale: Locale;
  service: ServiceEntry;
  projects: ProjectEntry[];
}
const { locale, service, projects } = Astro.props;
const s = service.data;
const localFaq =
  locale === "de"
    ? [
        {
          data: {
            question: `Was umfasst ein typisches Projekt für ${s.title}?`,
            answer:
              "Wir stellen Team und Umfang nach dem gewünschten Ergebnis zusammen und bestätigen dann eine klare Abfolge aus Recherche, Strategie, Produktion, Umsetzung und Messung.",
          },
        },
        {
          data: {
            question: "Wie schnell können wir starten?",
            answer:
              "Die meisten fokussierten Projekte beginnen innerhalb von zwei bis vier Wochen. Eingebettete Arbeit kann oft mit einem kurzen Discovery-Sprint starten.",
          },
        },
        {
          data: {
            question: "Können Sie mit unserem internen Team arbeiten?",
            answer:
              "Ja. Wir können den kompletten Arbeitsbereich verantworten oder eng mit internen Marken-, Produkt-, Marketing- und Engineering-Leads zusammenarbeiten.",
          },
        },
      ]
    : [
        {
          data: {
            question: `What does a typical ${s.title.toLowerCase()} project include?`,
            answer:
              "We set the team and scope around your goal, then agree on clear steps for research, planning, production, launch, and review.",
          },
        },
        {
          data: {
            question: "How quickly can we start?",
            answer:
              "Most focused projects begin within two to four weeks. Embedded work can often start with a short discovery sprint.",
          },
        },
        {
          data: {
            question: "Can you work with our internal team?",
            answer:
              "Yes. We can run the full project or work with your brand, product, marketing, and engineering leads.",
          },
        },
      ];
const process =
  locale === "de"
    ? [
        {
          title: "Entdecken",
          copy: "Geschäft, Zielgruppe, Belege, Einschränkungen und die Entscheidungen, die die Arbeit ermöglichen muss, abstimmen.",
        },
        {
          title: "Definieren",
          copy: "Die Erkenntnisse in eine klare Strategie, ein System und einen messbaren Lieferplan überführen.",
        },
        {
          title: "Umsetzen",
          copy: "In engen wöchentlichen Arbeitssitzungen gestalten, schreiben, bauen, testen und verfeinern.",
        },
        {
          title: "Starten & lernen",
          copy: "Sorgfältig veröffentlichen, das Wesentliche messen und frühe Erkenntnisse in die nächste Verbesserung überführen.",
        },
      ]
    : [
        {
          title: "Discover",
          copy: "Align on the business, audience, evidence, constraints, and the decisions the work must unlock.",
        },
        {
          title: "Define",
          copy: "Turn the facts into a clear plan with goals we can track.",
        },
        {
          title: "Make",
          copy: "Design, write, build, test, and refine in close weekly working sessions.",
        },
        {
          title: "Launch & learn",
          copy: "Ship carefully, measure what matters, and turn early evidence into the next improvement.",
        },
      ];
---

<BaseLayout {locale} title={s.title} description={s.summary}>
  <main id="main-content">
    <EditorialHero
      title={s.title}
      copy={s.summary}
    /><section class="service-detail-intro grid grid-cols-[1.15fr_.85fr] items-start gap-20 px-page py-section max-[900px]:grid-cols-1 max-[900px]:gap-12">
      <div class="service-statement">
        <span class="font-[var(--font-mono)] text-caption uppercase">{locale === "de" ? "Was wir lösen" : "What we solve"}</span><h2 class="my-6 text-heading-lg font-semibold">
          {
            locale === "de"
              ? "Jeden Schritt klarer, schneller und wertvoller machen."
              : "Make each step clearer, faster, and more useful."
          }
        </h2>
      </div><div class="tag-cloud grid content-start grid-cols-2 gap-2 border-t border-ink max-[600px]:grid-cols-1">
        {s.problems.map((problem) => <span class="flex min-h-18 items-center rounded-none border-b border-line bg-transparent p-3 text-caption">{problem}</span>)}
      </div>
    </section><section class="deliverables bg-dark px-page py-section text-inverse [&_.eyebrow]:bg-[#272727]">
      <SectionHeading
        title={locale === "de" ? "Was Sie erhalten." : "What you get."}
        align="center"
      /><NumberedList
        items={s.deliverables.map((title) => ({
          title,
          copy:
            locale === "de"
              ? `Erfahrene Fachleute für ${title}, von Anfang an auf Ihr Team, Ihre Kunden und Ihre Ziele abgestimmt.`
              : `Senior ${title.toLowerCase()} work, matched to your team, customers, and goals from day one.`,
        }))}
      />
    </section><section class="process-section bg-surface px-page py-section">
      <SectionHeading
        title={locale === "de"
          ? "Klare Schritte. Sorgfältige Arbeit."
          : "Clear steps. Careful work."}
        align="center"
      /><NumberedList items={process} />
    </section><section class="outcomes-section px-page py-section">
      <SectionHeading
        title={locale === "de"
          ? "Das wollen wir erreichen."
          : "What we aim to change."}
        align="center"
       /><div class="outcome-grid grid grid-cols-2 gap-3 max-[600px]:grid-cols-1">
        {
          s.outcomes.map((outcome, index) => (
            <div class="flex min-h-36 flex-col justify-between rounded-card bg-surface p-6 shadow-surface">
              <>
                <span class="font-[var(--font-mono)] text-caption text-[#888]">0{index + 1}</span>
                <h3 class="text-heading-sm font-semibold">{outcome}</h3>
              </>
            </div>
          ))
        }
      </div>
    </section><section class="case-tools service-tools mx-auto mt-0 grid max-w-layout grid-cols-[200px_1fr] border-b border-line py-section-compact max-[900px]:mx-page max-[600px]:grid-cols-1 max-[600px]:gap-6">
      <span class="font-[var(--font-mono)] text-caption uppercase">{locale === "de" ? "Relevante Tools" : "Relevant tools"}</span><div class="flex flex-wrap gap-2">
        {s.tools.map((tool) => <i class="rounded-card border border-[#ccc] px-[13px] py-[9px] text-caption not-italic">{tool}</i>)}
      </div>
    </section><RelatedWork
      title={locale === "de" ? "Passende Arbeiten" : "Related work"}
      {projects}
      {locale}
    /><section class="faq-section bg-canvas px-page py-section [&>.section-heading]:mx-auto [&>.section-heading]:text-center">
      <SectionHeading
        title={locale === "de" ? "Fragen zur Leistung" : "Service FAQs"}
        align="center"
      /><Faq items={localFaq} id={`service-faq-${locale}-${s.slug}`} />
    </section><FinalCta {locale} />
  </main>
</BaseLayout>
