---
import BaseLayout from "@/layouts/BaseLayout.astro";
import FinalCta from "@/components/FinalCta.astro";
import ProjectVisual from "@/components/ProjectVisual.astro";
import RelatedWork from "@/components/RelatedWork.astro";
import type { ProjectEntry } from "@/lib/content";
import type { Locale } from "@/lib/i18n";
interface Props { locale: Locale; project: ProjectEntry; related: ProjectEntry[]; }
const { locale, project, related } = Astro.props;
const p = project.data;
const structuredData = [{ "@context": "https://schema.org", "@type": "BreadcrumbList", itemListElement: [{ "@type": "ListItem", position: 1, name: locale === "de" ? "Arbeiten" : "Work", item: locale === "de" ? "/work" : "/en/work" }, { "@type": "ListItem", position: 2, name: p.title }] }];
---
<BaseLayout {locale} title={p.title} description={p.summary} {structuredData}>
  <main id="main-content"><article class="case-study"><header class="case-hero"><div class="case-meta"><span>{p.categories.join(" · ")}</span><span>{p.year}</span></div><h1>{p.title}</h1><p>{p.summary}</p><div class="case-visual-wrap"><ProjectVisual project={p} /></div></header><section class="case-summary"><div><span>{locale === "de" ? "Ergebnis" : "Result"}</span><strong>{p.metric}</strong><p>{p.metricLabel}</p></div><div><span>{locale === "de" ? "Zeitraum" : "Timeline"}</span><h2>{p.timeline}</h2></div><div><span>{locale === "de" ? "Leistungen" : "Services"}</span><p>{p.categories.join(", ")}</p></div></section><section class="case-narrative"><div><span>01 · {locale === "de" ? "Herausforderung" : "Challenge"}</span><h2>{p.challenge}</h2></div><div><span>02 · {locale === "de" ? "Strategie" : "Strategy"}</span><p>{p.strategy}</p></div><div><span>03 · {locale === "de" ? "Umsetzung" : "Execution"}</span><p>{p.execution}</p></div></section><section class="case-quote"><span>{locale === "de" ? "Kundenstimme" : "Client testimonial"}</span><blockquote>“{locale === "de" ? "Die Arbeit gab unserem gesamten Team eine klarere Geschichte, ein stärkeres System und bessere Grundlagen für Entscheidungen." : "The work gave our whole team a clearer story, a stronger system, and much better evidence for the decisions we make."}”</blockquote><p>{locale === "de" ? "Kunde" : "Client"}</p></section><section class="case-tools"><span>{locale === "de" ? "Eingesetzte Technologie" : "Technology used"}</span><div>{p.tools.map((tool) => <i>{tool}</i>)}</div></section></article><RelatedWork title={locale === "de" ? "Weitere Fallstudien" : "Next case studies"} projects={related} {locale} /><FinalCta {locale} /></main>
</BaseLayout>
