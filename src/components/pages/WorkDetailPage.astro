---
import BaseLayout from "@/layouts/BaseLayout.astro";
import FinalCta from "@/components/FinalCta.astro";
import ProjectVisual from "@/components/ProjectVisual.astro";
import RelatedWork from "@/components/RelatedWork.astro";
import type { ProjectEntry } from "@/lib/content";
import type { Locale } from "@/lib/i18n";
interface Props { locale: Locale; project: ProjectEntry; related: ProjectEntry[]; }
const { locale, project, related } = Astro.props;
const p = project.data;
const structuredData = [{ "@context": "https://schema.org", "@type": "BreadcrumbList", itemListElement: [{ "@type": "ListItem", position: 1, name: locale === "de" ? "Arbeiten" : "Work", item: locale === "de" ? "/work" : "/en/work" }, { "@type": "ListItem", position: 2, name: p.title }] }];
---
<BaseLayout {locale} title={p.title} description={p.summary} indexable={false} article {structuredData}>
  <main id="main-content">
    <article class="case-study">
      <header class="case-hero px-page pt-[5.75rem] text-center">
        <div class="case-meta hidden justify-between border-b border-line pb-2.5 text-caption"><span>{p.categories.join(" · ")}</span><span>{p.year}</span></div>
        <h1 class="mx-auto mt-16 mb-6 max-w-hero text-display-lg font-bold max-[600px]:mt-12 max-[600px]:text-[42px]">{p.title}</h1>
        <p class="mx-auto max-w-narrow text-lead leading-[1.55] text-[#60605c]">{p.summary}</p>
        <div class="case-visual-wrap mt-20 h-[760px] overflow-hidden rounded-card max-[900px]:h-[560px] max-[600px]:mt-[50px] max-[600px]:h-[430px] [&_.mock-window]:origin-center [&_.mock-window]:scale-120 [&_.project-visual]:h-full"><ProjectVisual project={p} /></div>
      </header>
      <section class="case-summary grid grid-cols-[1.5fr_1fr_1fr] gap-3 px-page pt-6 pb-section-compact max-[900px]:grid-cols-2 max-[600px]:grid-cols-1">
        <div class="col-auto flex min-h-[210px] flex-col rounded-card bg-surface p-6 shadow-surface max-[900px]:col-span-full max-[600px]:col-span-1"><span class="text-caption text-[#888]">{locale === "de" ? "Ergebnis" : "Result"}</span><strong class="mt-auto text-display-sm font-semibold tabular-nums">{p.metric}</strong><p class="mt-auto text-body leading-body text-[#555]">{p.metricLabel}</p></div>
        <div class="flex min-h-[210px] flex-col rounded-card bg-surface p-6 shadow-surface"><span class="text-caption text-[#888]">{locale === "de" ? "Zeitraum" : "Timeline"}</span><h2 class="mt-auto mb-0 text-heading-md font-semibold">{p.timeline}</h2></div>
        <div class="flex min-h-[210px] flex-col rounded-card bg-surface p-6 shadow-surface"><span class="text-caption text-[#888]">{locale === "de" ? "Leistungen" : "Services"}</span><p class="mt-auto text-body leading-body text-[#555]">{p.categories.join(", ")}</p></div>
      </section>
      <section class="case-narrative px-page py-section-compact">
        <div class="grid grid-cols-[180px_1fr] gap-12 border-t border-line py-12 max-[900px]:gap-6 max-[600px]:grid-cols-1 max-[600px]:gap-4"><span class="font-mono text-caption text-[#777]">01 · {locale === "de" ? "Herausforderung" : "Challenge"}</span><h2 class="m-0 text-heading-md font-semibold max-[600px]:text-[30px]">{p.challenge}</h2></div>
        <div class="grid grid-cols-[180px_1fr] gap-12 border-t border-line py-12 max-[900px]:gap-6 max-[600px]:grid-cols-1 max-[600px]:gap-4"><span class="font-mono text-caption text-[#777]">02 · {locale === "de" ? "Strategie" : "Strategy"}</span><p class="m-0 max-w-reading text-body-lg leading-body text-[#555] max-[600px]:text-[17px]">{p.strategy}</p></div>
        <div class="grid grid-cols-[180px_1fr] gap-12 border-t border-line py-12 max-[900px]:gap-6 max-[600px]:grid-cols-1 max-[600px]:gap-4"><span class="font-mono text-caption text-[#777]">03 · {locale === "de" ? "Umsetzung" : "Execution"}</span><p class="m-0 max-w-reading text-body-lg leading-body text-[#555] max-[600px]:text-[17px]">{p.execution}</p></div>
      </section>
      <section class="case-quote bg-[var(--accent-soft)] px-page py-section text-center"><span class="font-mono text-caption uppercase">{locale === "de" ? "Kundenstimme" : "Client testimonial"}</span><blockquote class="mx-auto my-6 max-w-[23ch] text-display-sm font-semibold">“{locale === "de" ? "Die Arbeit gab unserem gesamten Team eine klarere Geschichte, ein stärkeres System und bessere Grundlagen für Entscheidungen." : "The work gave our whole team a clearer story, a stronger system, and much better evidence for the decisions we make."}”</blockquote><p class="text-caption">{locale === "de" ? "Kunde" : "Client"}</p></section>
      <section class="case-tools mx-auto grid max-w-layout grid-cols-[200px_1fr] border-b border-line py-section-compact max-[900px]:mx-page max-[600px]:mx-0 max-[600px]:grid-cols-1 max-[600px]:gap-6"><span class="font-mono text-caption uppercase">{locale === "de" ? "Eingesetzte Technologie" : "Technology used"}</span><div class="flex flex-wrap gap-2">{p.tools.map((tool) => <i class="rounded-xl border border-[#ccc] px-[13px] py-[9px] text-caption not-italic">{tool}</i>)}</div></section>
    </article>
    <RelatedWork title={locale === "de" ? "Weitere Fallstudien" : "Next case studies"} projects={related} {locale} />
    <FinalCta {locale} />
  </main>
</BaseLayout>
