---
import BaseLayout from "@/layouts/BaseLayout.astro";
import EditorialHero from "@/components/EditorialHero.astro";
import FinalCta from "@/components/FinalCta.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import ServiceCategoryGrid from "@/components/ServiceCategoryGrid.astro";
import { getServices } from "@/lib/content";
import { t, type Locale } from "@/lib/i18n";

interface Props { locale: Locale; }
const { locale } = Astro.props;
const services = await getServices(locale);
const description = locale === "de"
  ? "Marke, Websites, Apps, SEO, Content, Paid Acquisition, Analytics und KI-Automatisierung aus einem Senior-Team."
  : "Brand, websites, apps, SEO, content, paid acquisition, analytics, and AI automation from one senior team.";
---
<BaseLayout {locale} title={t(locale, "Services")} {description}>
  <main id="main-content" class="page-main page-main--services">
    <EditorialHero title={locale === "de" ? "Spezialisten für jede Wachstumsphase." : "Specialists for every stage of growth."} copy={locale === "de" ? "Acht konkrete Leistungen, verbunden durch eine klare Strategie und ein verantwortliches Team." : "Eight concrete services, connected by one clear strategy and one accountable team."} />
    <section class="service-category-section page-section bg-canvas px-page py-section [&>.section-heading]:mx-auto [&>.section-heading]:text-center [&>.section-heading_p]:mx-auto">
      <SectionHeading title={locale === "de" ? "Was wir für Sie tun." : "What we can do for you."} copy={locale === "de" ? "Starten Sie mit einem Bereich oder verbinden Sie mehrere zu einem gemeinsamen System." : "Start with one area or connect several into one joined system."} align="center" />
      <ServiceCategoryGrid {services} {locale} />
    </section>
    <FinalCta {locale} />
  </main>
</BaseLayout>
