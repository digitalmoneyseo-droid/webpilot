---
import BaseLayout from "@/layouts/BaseLayout.astro";
import EditorialHero from "@/components/EditorialHero.astro";
import FinalCta from "@/components/FinalCta.astro";
import ServiceLinkGrid from "@/components/ServiceLinkGrid.astro";
import SplitCta from "@/components/SplitCta.astro";
import { getServices } from "@/lib/content";
import { localizePath, t, type Locale } from "@/lib/i18n";
interface Props { locale: Locale; }
const { locale } = Astro.props;
const services = await getServices(locale);
---
<BaseLayout {locale} title={t(locale, "Services")} description={locale === "de" ? "Branding-, Website-, App-, Such-, Akquise-, Analyse-, KI- und Automatisierungsleistungen." : "Branding, website, app, search, acquisition, analytics, AI, and automation services."}>
  <main id="main-content" class="page-main page-main--services"><EditorialHero eyebrow={locale === "de" ? "Kompetenzen" : "Capabilities"} index={`02 / ${t(locale, "Services")}`} title={locale === "de" ? "Ein Senior-Team von der ersten Idee bis zum messbaren Wachstum." : "One senior team from first idea to measurable growth."} copy={locale === "de" ? "Wir verbinden die Arbeit, die Wahrnehmung prägt, Nachfrage erzeugt, Aufmerksamkeit konvertiert und operative Reibung reduziert." : "We connect the work that shapes perception, creates demand, converts attention, and removes operational drag."} /><section class="services-index section-pad page-section"><ServiceLinkGrid {services} {locale} /></section><SplitCta title={locale === "de" ? "Brauchen Sie das ganze System?" : "Need the whole system?"} copy={locale === "de" ? "Unser eingebettetes Growth-Team vereint Strategie, Design, Entwicklung, Akquise, Content, Analytics und KI in einem koordinierten monatlichen Programm." : "Our embedded growth team brings strategy, design, development, acquisition, content, analytics, and AI into one coordinated monthly program."} href={localizePath("/contact", locale)} label={locale === "de" ? "Briefing besprechen" : "Discuss your brief"} /><FinalCta {locale} /></main>
</BaseLayout>
