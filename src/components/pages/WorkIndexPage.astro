---
import BaseLayout from "@/layouts/BaseLayout.astro";
import EditorialHero from "@/components/EditorialHero.astro";
import FinalCta from "@/components/FinalCta.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { getProjects } from "@/lib/content";
import { t, type Locale } from "@/lib/i18n";
interface Props { locale: Locale; }
const { locale } = Astro.props;
const projects = await getProjects(locale);
const filters = ["All", "Brand", "Website", "Product", "Growth", "SEO & GEO", "Content", "Social", "Paid Media", "AI", "Automation"];
---
<BaseLayout {locale} title={t(locale, "Work")} description={locale === "de" ? "Ausgewählte fiktive Marken-, Digital-, Wachstums- und KI-Systeme von Webpilot." : "Selected fictional brand, digital, growth, and AI systems by Webpilot."}>
  <main id="main-content"><EditorialHero eyebrow={t(locale, "Selected work")} index={`01 / ${t(locale, "Work")}`} title={t(locale, "Built to look exceptional. Designed to perform.")} copy={locale === "de" ? "Konzeptarbeiten aus Marke, digitalen Produkten, Nachfragegenerierung und intelligenten Abläufen." : "Concept work spanning brand, digital products, demand generation, and intelligent operations."} />
    <section class="work-index section-pad" data-portfolio><div class="filter-row" role="group" aria-label={locale === "de" ? "Projekte filtern" : "Filter projects"}>{filters.map((filter, index) => <button type="button" class:list={{ "is-active": index === 0 }} data-filter={filter} aria-pressed={index === 0 ? "true" : "false"}>{t(locale, filter)}</button>)}</div><p class="sr-only" aria-live="polite" data-result-count>{projects.length} {locale === "de" ? "Projekte" : "projects"}</p><div class="work-grid">{projects.map(({ data }, index) => <ProjectCard project={data} {locale} featured={index === 0} filterable />)}</div></section><FinalCta {locale} />
  </main>
  <script>
    document.querySelectorAll<HTMLElement>("[data-portfolio]").forEach((portfolio) => {
      const buttons = [...portfolio.querySelectorAll<HTMLButtonElement>("[data-filter]")];
      const projects = [...portfolio.querySelectorAll<HTMLElement>("[data-project]")];
      const announcement = portfolio.querySelector<HTMLElement>("[data-result-count]");
      buttons.forEach((button) => button.addEventListener("click", () => {
        const filter = button.dataset.filter ?? "All";
        buttons.forEach((item) => { const active = item === button; item.classList.toggle("is-active", active); item.setAttribute("aria-pressed", String(active)); });
        let count = 0;
        projects.forEach((project) => {
          const categories = JSON.parse(project.dataset.categories ?? "[]") as string[];
          const visible = filter === "All" || categories.includes(filter);
          project.hidden = !visible;
          project.classList.toggle("project-card--featured", filter === "All" && project === projects[0]);
          if (visible) count += 1;
        });
        if (announcement) announcement.textContent = `${count} ${document.documentElement.lang === "de" ? "Projekte" : "projects"}`;
      }));
    });
  </script>
</BaseLayout>
