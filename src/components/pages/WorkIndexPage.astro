---
import BaseLayout from "@/layouts/BaseLayout.astro";
import EditorialHero from "@/components/EditorialHero.astro";
import FinalCta from "@/components/FinalCta.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { getProjects } from "@/lib/content";
import { t, type Locale } from "@/lib/i18n";
interface Props { locale: Locale; }
const { locale } = Astro.props;
const projects = await getProjects(locale);
const categoryAliases: Readonly<Record<string, string>> = { Marke: "Brand", Wachstum: "Growth", Automatisierung: "Automation", Produkt: "Product" };
const filterCategories = (categories: string[]) => categories.map((category) => categoryAliases[category] ?? category);
const filters = [
  { id: "All", categories: [...new Set(projects.flatMap(({ data }) => filterCategories(data.categories)))] },
  { id: "Build", categories: ["Brand", "Website", "Product"] },
  { id: "Grow", categories: ["Growth", "SEO & GEO", "Content", "Social", "Paid Media"] },
  { id: "Automate", categories: ["AI", "Automation"] },
] as const;
---
<BaseLayout {locale} title={t(locale, "Work")} description={locale === "de" ? "Ausgewählte fiktive Arbeiten für Marken, Digital, Wachstum und KI." : "Selected fictional work across brand, digital, growth, and AI."}>
  <main id="main-content"><EditorialHero title={t(locale, "Built to look good and work well.")} copy={locale === "de" ? "Arbeiten für Marken, digitale Produkte, Nachfrage und klare Abläufe." : "Work across brands, digital products, demand, and useful tools."} />
    <section class="work-index section-pad" data-portfolio><div class="filter-row" role="group" aria-label={locale === "de" ? "Projekte nach Leistung filtern" : "Filter projects by service"}><span class="filter-indicator" aria-hidden="true"></span>{filters.map((filter, index) => <button type="button" class:list={{ "is-active": index === 0 }} data-filter={filter.id} data-categories={JSON.stringify(filter.categories)} aria-pressed={index === 0 ? "true" : "false"}>{t(locale, filter.id)}</button>)}</div><p class="sr-only" aria-live="polite" data-result-count>{projects.length} {locale === "de" ? "Projekte" : "projects"}</p><div class="work-grid">{projects.map(({ data }) => <ProjectCard project={data} {locale} filterable filterCategories={filterCategories(data.categories)} />)}</div></section><FinalCta {locale} />
  </main>
  <script>
    document.querySelectorAll<HTMLElement>("[data-portfolio]").forEach((portfolio) => {
      const buttons = [...portfolio.querySelectorAll<HTMLButtonElement>("[data-filter]")];
      const projects = [...portfolio.querySelectorAll<HTMLElement>("[data-project]")];
      const announcement = portfolio.querySelector<HTMLElement>("[data-result-count]");
      const indicator = portfolio.querySelector<HTMLElement>(".filter-indicator");

      const positionIndicator = (button: HTMLButtonElement, animate = true) => {
        if (!indicator) return;
        indicator.style.setProperty("--filter-x", `${button.offsetLeft}px`);
        indicator.style.setProperty("--filter-width", `${button.offsetWidth}px`);
        if (animate) indicator.classList.add("is-ready");
        else {
          indicator.classList.remove("is-ready");
          requestAnimationFrame(() => indicator.classList.add("is-ready"));
        }
      };

      if (buttons[0]) {
        positionIndicator(buttons[0], false);
      }
      const filterResizeObserver = new ResizeObserver(() => {
        const activeButton = buttons.find((item) => item.classList.contains("is-active"));
        if (activeButton) positionIndicator(activeButton, false);
      });
      filterResizeObserver.observe(portfolio.querySelector<HTMLElement>(".filter-row")!);

      projects.forEach((project, index) => {
        project.style.viewTransitionName = `portfolio-card-${index}`;
      });

      const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
      type ViewTransitionHandle = { finished: Promise<void>; skipTransition: () => void };
      type ViewTransitionDocument = Document & {
        startViewTransition?: (update: () => void) => ViewTransitionHandle;
      };
      let activeTransition: ViewTransitionHandle | null = null;

      const applyFilter = (button: HTMLButtonElement, animateIndicator = true) => {
        const filterCategories = JSON.parse(button.dataset.categories ?? "[]") as string[];
        buttons.forEach((item) => {
          const active = item === button;
          item.classList.toggle("is-active", active);
          item.setAttribute("aria-pressed", String(active));
        });
        positionIndicator(button, animateIndicator);

        let count = 0;
        projects.forEach((project) => {
          const categories = JSON.parse(project.dataset.categories ?? "[]") as string[];
          const visible = categories.some((category) => filterCategories.includes(category));
          project.hidden = !visible;
          if (visible) count += 1;
        });
        if (announcement) announcement.textContent = `${count} ${document.documentElement.lang === "de" ? "Projekte" : "projects"}`;
      };

      buttons.forEach((button) => button.addEventListener("click", (event) => {
        const viewTransitionDocument = document as ViewTransitionDocument;
        const keyboardActivated = event.detail === 0;
        if (keyboardActivated || reducedMotion.matches || !viewTransitionDocument.startViewTransition) {
          activeTransition?.skipTransition();
          activeTransition = null;
          applyFilter(button, !keyboardActivated);
          return;
        }

        activeTransition?.skipTransition();
        const transition = viewTransitionDocument.startViewTransition(() => applyFilter(button));
        activeTransition = transition;
        void transition.finished.finally(() => {
          if (activeTransition === transition) activeTransition = null;
        });
      }));
    });
  </script>
</BaseLayout>
