---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLegalOperator } from "@/config/legal";
import type { Locale } from "@/lib/i18n";
interface Props { locale: Locale; }
const { locale } = Astro.props;
const operator = getLegalOperator();
---
<BaseLayout {locale} title={locale === "de" ? "Impressum" : "Imprint"} description={locale === "de" ? "Anbieterkennzeichnung für Webpilot." : "Legal operator information for Webpilot."}>
  <main id="main-content"><article class="legal-page legal-page--standalone mx-auto min-h-0 max-w-reading px-page pt-36 pb-30 text-body"><span class="eyebrow block text-center">{locale === "de" ? "Rechtliches" : "Legal"}</span><h1 class="mx-auto mt-8 mb-16 block max-w-[14ch] text-center text-display-sm font-semibold">{locale === "de" ? "Impressum" : "Imprint"}</h1>{operator ? <><h2 class="mt-16 mb-4 text-heading-lg font-semibold">{operator.legalName}</h2><p class="text-[#555]">{operator.streetAddress}<br />{operator.postalCode} {operator.city}<br />{operator.country}</p>{operator.representative && <p class="text-[#555]">{locale === "de" ? "Vertreten durch" : "Represented by"}: {operator.representative}</p>}<p class="text-[#555]">E-Mail: <a href={`mailto:${operator.email}`}>{operator.email}</a></p>{operator.registerName && <p class="text-[#555]">{operator.registerName}: {operator.registerNumber}</p>}{operator.vatId && <p class="text-[#555]">VAT ID: {operator.vatId}</p>}</> : <><h2 class="mt-16 mb-4 text-heading-lg font-semibold">Webpilot Studio</h2><p class="text-[#555]"><a href="mailto:hello@webpilot.studio">hello@webpilot.studio</a></p></>}</article></main>
</BaseLayout>
