---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLegalOperator } from "@/config/legal";
import type { Locale } from "@/lib/i18n";
interface Props { locale: Locale; }
const { locale } = Astro.props;
const operator = getLegalOperator();
---
<BaseLayout {locale} title={locale === "de" ? "Impressum" : "Imprint"} description={locale === "de" ? "Anbieterkennzeichnung für Webpilot." : "Legal operator information for Webpilot."}>
  <main id="main-content"><article class="legal-page legal-page--standalone"><span class="eyebrow">{locale === "de" ? "Rechtliches" : "Legal"}</span><h1>{locale === "de" ? "Impressum" : "Imprint"}</h1>{operator ? <><h2>{operator.legalName}</h2><p>{operator.streetAddress}<br />{operator.postalCode} {operator.city}<br />{operator.country}</p>{operator.representative && <p>{locale === "de" ? "Vertreten durch" : "Represented by"}: {operator.representative}</p>}<p>E-Mail: <a href={`mailto:${operator.email}`}>{operator.email}</a></p>{operator.registerName && <p>{operator.registerName}: {operator.registerNumber}</p>}{operator.vatId && <p>VAT ID: {operator.vatId}</p>}</> : <><h2>Webpilot Studio</h2><p><a href="mailto:hello@webpilot.studio">hello@webpilot.studio</a></p></>}</article></main>
</BaseLayout>
