---
import BaseLayout from "@/layouts/BaseLayout.astro";
import EditorialHero from "@/components/EditorialHero.astro";
import FinalCta from "@/components/FinalCta.astro";
import NumberedList from "@/components/NumberedList.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import { getTeam } from "@/lib/content";
import { t, type Locale } from "@/lib/i18n";

interface Props { locale: Locale; }
const { locale } = Astro.props;
const team = await getTeam(locale);
const principles = locale === "de" ? [
  { title: "Senior-Leute machen die Arbeit", copy: "Die Personen im Raum recherchieren, gestalten, bauen und optimieren das System auch selbst." },
  { title: "Belege vor Meinung", copy: "Geschmack zählt, doch Kundenerkenntnisse, Leistungsdaten und eine klare strategische Argumentation halten die Arbeit ehrlich." },
  { title: "Verbunden statt isoliert", copy: "Wir planen Marke, Produkt, Technologie, Akquise, Content, Analytics und KI als ein kommerzielles System." },
  { title: "Nützlich statt theatralisch", copy: "Wir nutzen neue Technologie dort, wo sie Hebelwirkung schafft – nicht nur eine eindrucksvollere Präsentation." },
] : [
  { title: "Senior people do the work", copy: "The people you meet research, design, build, and improve the work." },
  { title: "Evidence before opinion", copy: "Taste matters, but customer insight, performance data, and a clear strategic argument keep the work honest." },
  { title: "Work as one team", copy: "We plan brand, product, tech, marketing, content, data, and AI together." },
  { title: "Use before show", copy: "We use new tech when it helps the work, not when it only looks good in a pitch." },
];
---
<BaseLayout {locale} title={t(locale, "About")} description={locale === "de" ? "Das erfahrene Team hinter Webpilot." : "The senior team behind Webpilot."}>
  <main id="main-content" class="page-main page-main--about">
    <EditorialHero eyebrow={locale === "de" ? "Über das Studio" : "About the studio"} index={`03 / ${t(locale, "About")}`} title={locale === "de" ? "Bewusst klein. Stark in den wichtigen Feldern." : "Small team. Wide skill set."} copy={locale === "de" ? "Webpilot verbindet klares Design mit messbarem Wachstum und KI." : "Webpilot joins strong design, measured growth, and AI in one senior team."} showMeta={false} />
    <section class="about-manifesto section-pad">
      <div class="manifesto-mark"><span>{locale === "de" ? "Unabhängiges Studio" : "Independent studio"}</span><span>Berlin / Worldwide</span><span>{locale === "de" ? "Nur Senior-Team" : "Senior team only"}</span></div>
      <div><h2>{locale === "de" ? "Wachstum braucht ein klares Versprechen, ein gutes Produkt, eine sichtbare Marke und stetes Lernen." : "Growth needs a clear promise, a useful product, a visible brand, and steady learning."}</h2><p>{locale === "de" ? "Unser Team deckt mehr als eine Fachrichtung ab. Wer die Geschichte prägt, versteht auch Bau, Vertrieb, Messung und Pflege." : "Our team spans several fields. The people who shape the story also know how to build, sell, measure, and improve it."}</p></div>
    </section>
    <section class="principles section-pad page-section"><SectionHeading eyebrow={locale === "de" ? "Prinzipien" : "Principles"} title={locale === "de" ? "Wie wir arbeiten." : "How we work."} align="center" /><NumberedList items={principles} /></section>
    <section class="about-team section-pad page-section">
      <SectionHeading eyebrow={locale === "de" ? "Team" : "Team"} title={locale === "de" ? "Unterschiedliche Disziplinen. Ein Standard." : "Different disciplines. One standard."} align="center" />
      <div class="team-roster">{team.map(({ data }, index) => <div class="team-roster-row"><span>{String(index + 1).padStart(2, "0")}</span><strong>{data.name}</strong><small>{data.role}</small><b>{data.initials}</b></div>)}</div>
    </section>
    <FinalCta {locale} />
  </main>
</BaseLayout>
