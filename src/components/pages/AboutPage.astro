---
import BaseLayout from "@/layouts/BaseLayout.astro";
import EditorialHero from "@/components/EditorialHero.astro";
import FinalCta from "@/components/FinalCta.astro";
import NumberedList from "@/components/NumberedList.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import { t, type Locale } from "@/lib/i18n";

interface Props { locale: Locale; }
const { locale } = Astro.props;
const principles = locale === "de" ? [
  { title: "Senior-Leute machen die Arbeit", copy: "Die Personen im Raum recherchieren, gestalten, bauen und optimieren das System auch selbst." },
  { title: "Belege vor Meinung", copy: "Geschmack zählt, doch Kundenerkenntnisse, Leistungsdaten und eine klare strategische Argumentation halten die Arbeit ehrlich." },
  { title: "Verbunden statt isoliert", copy: "Wir planen Marke, Produkt, Technologie, Akquise, Content, Analytics und KI als ein kommerzielles System." },
  { title: "Nützlich statt theatralisch", copy: "Wir nutzen neue Technologie dort, wo sie Hebelwirkung schafft – nicht nur eine eindrucksvollere Präsentation." },
] : [
  { title: "Senior people do the work", copy: "The people you meet research, design, build, and improve the work." },
  { title: "Evidence before opinion", copy: "Taste matters, but customer insight, performance data, and a clear strategic argument keep the work honest." },
  { title: "Work as one team", copy: "We plan brand, product, tech, marketing, content, data, and AI together." },
  { title: "Use before show", copy: "We use new tech when it helps the work, not when it only looks good in a pitch." },
];
---
<BaseLayout {locale} title={t(locale, "About")} description={locale === "de" ? "Das erfahrene Team hinter Webpilot." : "The senior team behind Webpilot."}>
  <main id="main-content" class="page-main page-main--about">
    <EditorialHero title={locale === "de" ? "Bewusst klein. Stark in den wichtigen Feldern." : "Small team. Wide skill set."} copy={locale === "de" ? "Webpilot verbindet klares Design mit messbarem Wachstum und KI." : "Webpilot joins strong design, measured growth, and AI in one senior team."} />
    <section class="about-manifesto mx-auto grid w-[min(100%,calc(var(--layout-max)+(2*var(--space-6))))] max-w-none grid-cols-[minmax(0,.85fr)_minmax(0,1.15fr)] items-stretch gap-12 bg-[#111] px-8 py-section text-white max-[900px]:grid-cols-1 max-[900px]:gap-6 max-[600px]:gap-12 max-[600px]:px-6">
      <div class="manifesto-mark flex self-end flex-col justify-end gap-0 text-label font-medium uppercase text-white max-[600px]:order-2"><span class="border-t border-[#333] py-3">{locale === "de" ? "Unabhängiges Studio" : "Independent studio"}</span><span class="border-t border-[#333] py-3">Berlin / Worldwide</span><span class="border-t border-[#333] py-3">{locale === "de" ? "Nur Senior-Team" : "Senior team only"}</span></div>
      <div class="min-w-0"><h2 class="mb-4 max-w-[22ch] text-heading-lg font-semibold">{locale === "de" ? "Wachstum braucht ein klares Versprechen, ein gutes Produkt, eine sichtbare Marke und stetes Lernen." : "Growth needs a clear promise, a useful product, a visible brand, and steady learning."}</h2><p class="m-0 max-w-[540px] text-body text-[#999]">{locale === "de" ? "Unser Team deckt mehr als eine Fachrichtung ab. Wer die Geschichte prägt, versteht auch Bau, Vertrieb, Messung und Pflege." : "Our team spans several fields. The people who shape the story also know how to build, sell, measure, and improve it."}</p></div>
    </section>
    <section class="principles page-section mx-auto w-[min(100%,calc(var(--layout-max)+(2*var(--space-6))))] max-w-none bg-surface px-8 py-section max-[600px]:px-6"><SectionHeading title={locale === "de" ? "Wie wir arbeiten." : "How we work."} align="center" /><NumberedList items={principles} /></section>
    <FinalCta {locale} />
  </main>
</BaseLayout>
