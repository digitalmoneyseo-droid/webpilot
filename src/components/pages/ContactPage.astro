---
import BaseLayout from "@/layouts/BaseLayout.astro";
import "@/styles/contact-form.css";
import { turnstileSiteKey } from "@/lib/site";
import type { Locale } from "@/lib/i18n";
import { contactBudgets, localizedCategoryTitle, serviceCategories } from "@/domain/catalog";

interface Props { locale: Locale; }

const { locale } = Astro.props;
const interests = [
  ...serviceCategories.map((category) => [category.id, localizedCategoryTitle(category, locale)] as const),
  ["other", locale === "de" ? "Anderes / noch unsicher" : "Other / not sure yet"] as const,
];
const budgets = contactBudgets.map(({ id, label }) => [id, label[locale]] as const);
---

<BaseLayout
  {locale}
  title={locale === "de" ? "Kontakt" : "Contact"}
  description={locale === "de" ? "Starten Sie ein Gespräch mit Webpilot." : "Start a conversation with Webpilot."}
>
  <main id="main-content" class="page-main page-main--contact">
    <section class="contact-page">
      <div class="contact-intro">
        <h1>{locale === "de" ? <>Lassen Sie uns Ihr Wachstum <wbr />voranbringen.</> : "Let’s help your business grow."}</h1>
        <p>{locale === "de" ? "Sagen Sie uns, was Sie bauen, was Sie bremst und welches Ziel Sie erreichen wollen." : "Tell us what you are building, what holds it back, and what result you want."}</p>
        <a href="mailto:hello@webpilot.studio">hello@webpilot.studio ↗</a>
      </div>

      <form class="contact-form" action="/api/contact" method="post" enctype="application/x-www-form-urlencoded" data-contact-form novalidate>
        <header class="contact-form-header">
          <h2>{locale === "de" ? "Ein paar Details genügen." : "A few details are enough."}</h2>
          <p>{locale === "de" ? "Wählen Sie aus, was passt. Mehrere Leistungen und „noch unsicher“ sind völlig in Ordnung." : "Choose whatever fits. Multiple services and “not sure yet” are completely fine."}</p>
        </header>

        <div class="form-status" role="status" aria-live="polite" tabindex="-1" data-form-status hidden></div>

        <section class="form-section form-section--about" aria-labelledby="contact-details-heading">
          <h3 id="contact-details-heading">{locale === "de" ? "Über Sie" : "About you"}</h3>
          <div class="form-row">
            <label class="form-field" data-field="name">
              <span>{locale === "de" ? "Ihr Name" : "Your name"}</span>
              <input id="contact-name" name="name" type="text" autocomplete="name" minlength="2" maxlength="100" required placeholder="Ada Lovelace" aria-describedby="name-error" />
              <small class="field-message" id="name-error" aria-live="polite" data-field-error></small>
            </label>
            <label class="form-field" data-field="email">
              <span>{locale === "de" ? "Geschäftliche E-Mail" : "Work email"}</span>
              <span class="form-control form-control--email">
                <input id="contact-email" name="email" type="email" autocomplete="email" maxlength="254" required spellcheck="false" placeholder="ada@company.com" aria-describedby="email-hint" data-email-input />
                <span class="email-valid-icon" aria-hidden="true">✓</span>
              </span>
              <small class="field-message" id="email-hint" aria-live="polite" data-email-hint data-field-error></small>
            </label>
          </div>

          <label class="form-field">
            <span>{locale === "de" ? "Unternehmen" : "Company"} <em>({locale === "de" ? "optional" : "optional"})</em></span>
            <input name="company" type="text" autocomplete="organization" maxlength="120" placeholder={locale === "de" ? "Unternehmensname" : "Company name"} />
          </label>
        </section>

        <fieldset class="form-services form-section" data-field="interests">
          <legend>{locale === "de" ? "Wobei können wir helfen?" : "What can we help with?"} <em class="required-marker" aria-hidden="true">*</em><span class="sr-only"> {locale === "de" ? "Pflichtfeld" : "Required"}</span></legend>
          <p class="form-section-note">{locale === "de" ? "Mehrfachauswahl möglich" : "Select all that apply"}</p>
          <div class="form-options form-options--services">
            {interests.map(([value, label]) => (
              <label>
                <input type="checkbox" name="interests" value={value} />
                <span><b>{label}</b></span>
              </label>
            ))}
          </div>
          <small class="field-message" aria-live="polite" data-field-error></small>
        </fieldset>

        <section class="form-section form-section--project" aria-labelledby="project-heading" data-field="brief">
          <h3 id="project-heading">{locale === "de" ? "Ihr Projekt" : "Your project"} <em class="required-marker" aria-hidden="true">*</em></h3>
          <label class="form-field form-field--brief">
            <span class="sr-only">{locale === "de" ? "Projektdetails" : "Project details"}</span>
            <span class="form-input-group">
              <textarea id="contact-brief" name="brief" minlength="20" maxlength="4000" required rows="6" placeholder={locale === "de" ? "Projekt, Problem und Ziel…" : "Project, problem, and goal…"} aria-describedby="brief-description brief-error"></textarea>
              <span class="form-character-count" data-character-count>0/4000 {locale === "de" ? "Zeichen" : "characters"}</span>
            </span>
            <span class="form-description" id="brief-description">{locale === "de" ? "Beschreiben Sie Ausgangslage, Ziel und was aktuell nicht klappt." : "Include the current situation, desired result, and what does not work."}</span>
            <small class="field-message" id="brief-error" aria-live="polite" data-field-error></small>
          </label>
        </section>

        <fieldset class="form-services form-section form-budget">
          <legend>{locale === "de" ? "Mit welchem Budgetrahmen arbeiten Sie?" : "What budget range are you working with?"} <em>({locale === "de" ? "optional" : "optional"})</em></legend>
          <p class="form-section-note">{locale === "de" ? "Eine Auswahl" : "Choose one"}</p>
          <div class="form-options form-options--budget">
            {budgets.map(([value, label]) => (
              <label>
                <input type="radio" name="budget" value={value} />
                <span><b>{label}</b></span>
              </label>
            ))}
          </div>
        </fieldset>

        <input type="hidden" name="locale" value={locale} />
        <label class="website-field" aria-hidden="true"><span>Website</span><input name="website" type="text" tabindex="-1" autocomplete="off" /></label>
        <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="light" data-size="flexible" data-appearance="interaction-only"></div>
        <div class="form-actions">
          <button class="form-reset" type="reset" data-reset-button>{locale === "de" ? "Zurücksetzen" : "Reset"}</button>
          <button class="form-submit" type="submit" data-submit-button data-state="idle">
            <span class="form-submit__idle">{locale === "de" ? "Anfrage senden" : "Send enquiry"}</span>
            <span class="form-submit__pending" aria-hidden="true">
              <span class="form-submit__spinner" aria-hidden="true"></span>
              <span>{locale === "de" ? "Wird gesendet…" : "Sending…"}</span>
            </span>
          </button>
        </div>
        <small>{locale === "de" ? "Ihre Angaben werden nur zur Beantwortung der Anfrage verarbeitet und nicht von Webpilot gespeichert." : "Your details are processed only to answer this request and are not stored by Webpilot."}</small>
      </form>
    </section>
  </main>

  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  <script>
    const status = document.querySelector<HTMLElement>("[data-form-status]");
    const state = new URLSearchParams(window.location.search).get("status");
    if (status && state) {
      status.hidden = false;
      const de = document.documentElement.lang === "de";
      status.textContent = state === "success"
        ? (de ? "Danke — Ihre Anfrage wurde gesendet." : "Thank you — your request was sent.")
        : (de ? "Die Anfrage konnte nicht gesendet werden. Bitte prüfen Sie Ihre Angaben oder schreiben Sie uns per E-Mail." : "The request could not be sent. Check your details or email us instead.");
      status.focus();
    }

    const form = document.querySelector<HTMLFormElement>("[data-contact-form]");
    const brief = form?.querySelector<HTMLTextAreaElement>('textarea[name="brief"]');
    const email = form?.querySelector<HTMLInputElement>("[data-email-input]");
    const characterCount = form?.querySelector<HTMLElement>("[data-character-count]");
    const de = document.documentElement.lang === "de";
    const touched = new Set<string>();

    const messages = {
      name: de ? "Der Name muss mindestens 2 Zeichen lang sein." : "Name must be at least 2 characters.",
      email: de ? "Geben Sie eine gültige E-Mail-Adresse ein." : "Enter a valid email address.",
      interests: de ? "Wählen Sie mindestens einen Bereich aus." : "Choose at least one area of interest.",
      brief: de ? "Die Projektbeschreibung muss mindestens 20 Zeichen lang sein." : "Project details must be at least 20 characters.",
    } as const;

    type FieldName = keyof typeof messages;

    const updateCharacterCount = () => {
      if (!brief || !characterCount) return;
      characterCount.textContent = `${brief.value.length}/4000 ${de ? "Zeichen" : "characters"}`;
    };

    const setFieldState = (name: FieldName, invalid: boolean) => {
      const field = form?.querySelector<HTMLElement>(`[data-field="${name}"]`);
      if (!field) return;
      field.dataset.invalid = invalid ? "true" : "false";
      field.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>("input, textarea").forEach((control) => {
        control.setAttribute("aria-invalid", invalid ? "true" : "false");
      });
      const error = field.querySelector<HTMLElement>("[data-field-error]");
      if (error) error.textContent = invalid ? messages[name] : "";
    };

    const validateField = (name: FieldName) => {
      if (!form) return false;
      let valid = false;
      if (name === "name") {
        valid = (form.elements.namedItem("name") as HTMLInputElement).value.trim().length >= 2;
      } else if (name === "email") {
        const value = email?.value.trim() ?? "";
        valid = value.length > 0 && Boolean(email?.validity.valid);
        if (email) email.dataset.validation = valid ? "valid" : value ? "invalid" : "empty";
      } else if (name === "interests") {
        valid = Boolean(form.querySelector('input[name="interests"]:checked'));
      } else {
        valid = (brief?.value.trim().length ?? 0) >= 20;
      }
      setFieldState(name, !valid);
      return valid;
    };

    (["name", "email", "brief"] as const).forEach((name) => {
      const control = form?.elements.namedItem(name) as HTMLInputElement | HTMLTextAreaElement | null;
      control?.addEventListener("blur", () => {
        touched.add(name);
        validateField(name);
      });
      control?.addEventListener("input", () => {
        if (name === "brief") updateCharacterCount();
        if (touched.has(name)) validateField(name);
      });
    });

    form?.querySelectorAll<HTMLInputElement>('input[name="interests"]').forEach((control) => {
      control.addEventListener("change", () => {
        touched.add("interests");
        validateField("interests");
      });
    });

    form?.addEventListener("reset", () => {
      window.setTimeout(() => {
        touched.clear();
        (["name", "email", "interests", "brief"] as const).forEach((name) => setFieldState(name, false));
        if (email) email.dataset.validation = "empty";
        updateCharacterCount();
      });
    });

    updateCharacterCount();

    form?.addEventListener("submit", (event) => {
      const fields = ["name", "email", "interests", "brief"] as const;
      fields.forEach((name) => touched.add(name));
      const validity = fields.map(validateField);
      const valid = validity.every(Boolean);
      const submitButton = form.querySelector<HTMLButtonElement>("[data-submit-button]");
      if (valid) {
        if (status) status.hidden = true;
        if (submitButton) {
          submitButton.dataset.state = "submitting";
          submitButton.disabled = true;
          submitButton.setAttribute("aria-busy", "true");
          submitButton.setAttribute("aria-label", document.documentElement.lang === "de" ? "Anfrage wird gesendet" : "Sending enquiry");
          submitButton.querySelector<HTMLElement>(".form-submit__pending")?.setAttribute("aria-hidden", "false");
        }
        return;
      }
      event.preventDefault();
      const firstInvalid = fields.find((_name, index) => !validity[index]);
      if (status && firstInvalid) {
        status.textContent = messages[firstInvalid];
        status.hidden = false;
      }
      form.querySelector<HTMLElement>('[aria-invalid="true"]')?.focus();
    });
  </script>
</BaseLayout>
