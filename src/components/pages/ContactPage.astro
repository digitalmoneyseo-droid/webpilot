---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { contactFormEnabled, siteMode, turnstileSiteKey } from "@/lib/site";
import type { Locale } from "@/lib/i18n";
interface Props { locale: Locale; }
const { locale } = Astro.props;
const interests = locale === "de" ? [
  ["brand-website", "Marke & Website"], ["seo-ai-search", "SEO & KI-Suche"], ["content-paid", "Content & Paid"], ["ai-automation", "KI & Automation"], ["analytics-cro", "Analytics & CRO"], ["embedded-team", "Eingebettetes Team"],
] : [
  ["brand-website", "Brand & website"], ["seo-ai-search", "SEO & AI search"], ["content-paid", "Content & paid"], ["ai-automation", "AI & automation"], ["analytics-cro", "Analytics & CRO"], ["embedded-team", "Embedded team"],
];
---
<BaseLayout {locale} title={locale === "de" ? "Kontakt" : "Contact"} description={locale === "de" ? "Starten Sie ein Gespräch mit Webpilot." : "Start a conversation with Webpilot."}>
  <main id="main-content"><section class="contact-page"><div class="contact-intro"><span>05 / {locale === "de" ? "Kontakt" : "Contact"}</span><h1>{locale === "de" ? "Lassen Sie uns Ihr nächstes Wachstumssystem bauen." : "Let’s build your next growth system."}</h1><p>{locale === "de" ? "Erzählen Sie uns, was Sie aufbauen, wo Wachstum stockt und wie ein starkes Ergebnis aussehen würde." : "Tell us what you are building, where growth is getting stuck, and what a strong outcome would look like."}</p><a href="mailto:hello@webpilot.studio">hello@webpilot.studio ↗</a></div>
      {contactFormEnabled ? <form class="contact-form" action="/api/contact" method="post" enctype="application/x-www-form-urlencoded" data-contact-form>
        <div class="form-status" role="status" aria-live="polite" tabindex="-1" data-form-status hidden></div>
        <label><span>{locale === "de" ? "Ihr Name" : "Your name"}</span><input name="name" type="text" autocomplete="name" minlength="2" maxlength="100" required placeholder="Ada Lovelace" /></label>
        <label><span>{locale === "de" ? "Geschäftliche E-Mail" : "Work email"}</span><input name="email" type="email" autocomplete="email" maxlength="254" required placeholder="ada@company.com" /></label>
        <label><span>{locale === "de" ? "Unternehmen" : "Company"}</span><input name="company" type="text" autocomplete="organization" maxlength="120" placeholder={locale === "de" ? "Unternehmensname" : "Company name"} /></label>
        <fieldset><legend>{locale === "de" ? "Wobei können wir helfen?" : "What can we help with?"}</legend><div class="form-options">{interests.map(([value, label]) => <label><input type="checkbox" name="interests" value={value} /><span>{label}</span></label>)}</div></fieldset>
        <label><span>{locale === "de" ? "Was möchten Sie erreichen?" : "What are you trying to achieve?"}</span><textarea name="brief" minlength="20" maxlength="4000" required rows="5" placeholder={locale === "de" ? "Ein wenig Kontext, die wichtigste Einschränkung und wie Erfolg aussieht…" : "A little context, the important constraint, and what success looks like…"}></textarea></label>
        <label><span>{locale === "de" ? "Investitionsrahmen" : "Indicative investment"}</span><select name="budget"><option value="">{locale === "de" ? "Bereich wählen" : "Select a range"}</option><option value="15-30k">€15k–€30k</option><option value="30-60k">€30k–€60k</option><option value="60-120k">€60k–€120k</option><option value="120k-plus">€120k+</option></select></label>
        <input type="hidden" name="locale" value={locale} /><label class="website-field" aria-hidden="true"><span>Website</span><input name="website" type="text" tabindex="-1" autocomplete="off" /></label>
        <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="light"></div>
        <button class="form-submit" type="submit">{locale === "de" ? "Projektanfrage senden" : "Send project brief"} <span>↗</span></button><small>{locale === "de" ? "Ihre Angaben werden nur zur Beantwortung der Anfrage verarbeitet und nicht von Webpilot gespeichert." : "Your details are processed only to answer this request and are not stored by Webpilot."}</small>
      </form> : <div class="contact-form concept-contact-notice"><span class="eyebrow">{locale === "de" ? "Konzeptmodus" : "Concept mode"}</span><h2>{locale === "de" ? "Das Kontaktformular ist noch nicht aktiv." : "The contact form is not active yet."}</h2><p>{locale === "de" ? "Diese Website wurde noch nicht veröffentlicht. Damit keine personenbezogenen Daten gesammelt werden, bleibt das vollständig implementierte Formular bis zum Live-Modus deaktiviert." : "This website has not launched. To avoid collecting personal data, the fully implemented form remains disabled until live mode."}</p><a class="pill-button" href="mailto:hello@webpilot.studio">hello@webpilot.studio ↗</a><small>{locale === "de" ? "Aktueller Modus" : "Current mode"}: {siteMode}</small></div>}
    </section></main>
  {contactFormEnabled && <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>}
  {contactFormEnabled && <script>
    const status = document.querySelector<HTMLElement>("[data-form-status]");
    const state = new URLSearchParams(window.location.search).get("status");
    if (status && state) {
      status.hidden = false;
      const de = document.documentElement.lang === "de";
      status.textContent = state === "success" ? (de ? "Danke — Ihre Anfrage wurde gesendet." : "Thank you — your request was sent.") : (de ? "Die Anfrage konnte nicht gesendet werden. Bitte prüfen Sie Ihre Angaben oder schreiben Sie uns per E-Mail." : "The request could not be sent. Check your details or email us instead.");
      status.focus();
    }
    document.querySelector<HTMLFormElement>("[data-contact-form]")?.addEventListener("submit", (event) => {
      const form = event.currentTarget as HTMLFormElement;
      const interests = form.querySelectorAll<HTMLInputElement>('input[name="interests"]:checked');
      if (interests.length) return;
      event.preventDefault();
      if (!status) return;
      status.hidden = false;
      status.textContent = document.documentElement.lang === "de" ? "Bitte wählen Sie mindestens einen Interessenbereich." : "Choose at least one area of interest.";
      status.focus();
    });
  </script>}
</BaseLayout>
