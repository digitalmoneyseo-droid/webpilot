---
import BaseLayout from "@/layouts/BaseLayout.astro";
import EditorialHero from "@/components/EditorialHero.astro";
import FinalCta from "@/components/FinalCta.astro";
import { getInsights } from "@/lib/content";
import { formatDate, localizePath, t, type Locale } from "@/lib/i18n";
interface Props { locale: Locale; }
const { locale } = Astro.props;
const insights = await getInsights(locale);
---
<BaseLayout {locale} title={t(locale, "Insights")} description={locale === "de" ? "Webpilots Perspektiven auf Marke, digitale Produkte, Wachstum, Daten, KI und Automatisierung." : "Webpilot perspectives on brand, digital products, growth, data, AI, and automation."}>
  <main id="main-content" class="page-main page-main--insights"><EditorialHero eyebrow={locale === "de" ? "Ideen & Perspektiven" : "Ideas & perspectives"} index={`04 / ${t(locale, "Insights")}`} title={locale === "de" ? "Klares Denken für verbundenes Wachstum." : "Clear thinking for connected growth."} copy={locale === "de" ? "Eigene Perspektiven darauf, wie Marke, digitale Produkte, Nachfrage und intelligente Systeme als Einheit funktionieren können." : "Original perspectives on making brand, digital products, demand, and intelligent systems work as one."} /><section class="insights-grid section-pad page-section">{insights.map(({ data }, index) => <a href={localizePath(`/insights/${data.slug}`, locale)} class={`insight-card insight-card-${(index % 3) + 1}`}><div class="insight-art"><i></i><i></i><b>{data.category}</b></div><div class="insight-meta"><span>{formatDate(locale, data.publishedAt)}</span><span>{data.readMinutes} {locale === "de" ? "Min. Lesezeit" : "min read"}</span></div><h2>{data.title}</h2><p>{data.excerpt}</p><b>{locale === "de" ? "Artikel lesen ↗" : "Read article ↗"}</b></a>)}</section><FinalCta {locale} /></main>
</BaseLayout>
