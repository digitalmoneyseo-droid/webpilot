---
import BaseLayout from "@/layouts/BaseLayout.astro";
import EditorialHero from "@/components/EditorialHero.astro";
import FinalCta from "@/components/FinalCta.astro";
import { getInsights } from "@/lib/content";
import { formatDate, localizePath, t, type Locale } from "@/lib/i18n";
interface Props { locale: Locale; }
const { locale } = Astro.props;
const insights = await getInsights(locale);
---
<BaseLayout {locale} title={t(locale, "Insights")} description={locale === "de" ? "Praktische Konzeptnotizen zu Marke, Wachstum, Suche, Analytics und KI-Systemen." : "Practical concept notes on brand, growth, search, analytics, and AI systems."}>
  <main id="main-content"><EditorialHero eyebrow={locale === "de" ? "Ideen & Feldnotizen" : "Ideas & field notes"} index={`04 / ${t(locale, "Insights")}`} title={locale === "de" ? "Klares Denken für verbundenes Wachstum." : "Clear thinking for connected growth."} copy={locale === "de" ? "Praktische Perspektiven auf Marken, Nachfragesysteme und nützliche Automatisierung — als fiktives Konzeptmaterial." : "Practical perspectives on building brands, demand systems, and useful automation — presented as fictional concept material."} /><section class="insights-grid section-pad">{insights.map(({ data }, index) => <a href={localizePath(`/insights/${data.slug}`, locale)} class={`insight-card insight-card-${(index % 3) + 1}`}><div class="insight-art"><span>{String(index + 1).padStart(2, "0")}</span><i></i><i></i><b>{data.category}</b></div><div class="insight-meta"><span>{formatDate(locale, data.publishedAt)}</span><span>{data.readMinutes} {locale === "de" ? "Min. Lesezeit" : "min read"}</span></div><h2>{data.title}</h2><p>{data.excerpt}</p><b>{locale === "de" ? "Konzeptartikel lesen ↗" : "Read concept article ↗"}</b></a>)}</section><FinalCta {locale} /></main>
</BaseLayout>
