---
import { ChartNoAxesCombined, PanelsTopLeft, Workflow } from "@lucide/astro";

interface Props {
  name: "build" | "grow" | "automate";
}

const { name } = Astro.props;
---

<div class={`service-symbol symbol-${name} relative mt-3 -mx-2.5 mb-8 grid h-44 place-items-center max-[600px]:h-36`} aria-hidden="true">
  <span></span><span></span>
  {name === "build" && <PanelsTopLeft />}
  {name === "grow" && <ChartNoAxesCombined />}
  {name === "automate" && <Workflow />}
</div>
