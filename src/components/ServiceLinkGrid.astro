---
import type { ServiceEntry } from "@/lib/content";
import { localizePath, type Locale } from "@/lib/i18n";
import { localizedPillarDescription, localizedPillarTitle, localizedServiceCount, servicePillars, servicesForPillar } from "@/lib/services";
interface Props { services: ServiceEntry[]; locale: Locale; }
const { services, locale } = Astro.props;
---
<nav class="service-pillar-nav" aria-label={locale === "de" ? "Leistungsbereiche" : "Service pillars"}>
  {servicePillars.map((pillar) => {
    const count = servicesForPillar(services, pillar.id).length;
    return <a href={`#${pillar.id}`}>
      <span>{pillar.number}</span>
      <strong>{localizedPillarTitle(pillar, locale)}</strong>
      <small>{localizedServiceCount(count, locale)}</small>
    </a>;
  })}
</nav>

<div class="service-pillar-list">
  {servicePillars.map((pillar) => {
    const pillarServices = servicesForPillar(services, pillar.id);
    return <section class={`service-pillar service-pillar--${pillar.id}`} id={pillar.id} aria-labelledby={`${pillar.id}-title`}>
      <header class="service-pillar-header">
        <div class="service-pillar-meta"><span>{pillar.number} / {locale === "de" ? "Leistungsbereich" : "Pillar"}</span><small>{localizedServiceCount(pillarServices.length, locale)}</small></div>
        <h2 id={`${pillar.id}-title`}>{localizedPillarTitle(pillar, locale)}</h2>
        <p>{localizedPillarDescription(pillar, locale)}</p>
      </header>
      <div class="service-link-grid">
        {pillarServices.map((service) => <a href={localizePath(`/services/${service.data.slug}`, locale)}>
          <span>{String(service.data.order).padStart(2, "0")}</span>
          <div><h3>{service.data.title}</h3><p>{service.data.summary}</p></div>
          <b>{locale === "de" ? "Entdecken ↗" : "Explore ↗"}</b>
        </a>)}
      </div>
    </section>;
  })}
</div>
