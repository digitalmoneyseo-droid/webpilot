---
import Icon from "@/components/Icon.astro";
interface Props { href: string; light?: boolean; external?: boolean; class?: string; }
const { href, light = false, external = false, class: extraClass } = Astro.props;
---
<a class:list={["pill-button inline-flex min-h-[var(--control-height-lg)] items-center gap-3.5 rounded-pill py-0 pr-2.5 pl-[var(--control-padding-x)] text-control font-medium shadow-dark-surface max-[600px]:justify-between", extraClass, { "pill-button--light bg-white text-ink": light, "bg-dark text-white": !light }]} href={href} target={external ? "_blank" : undefined} rel={external ? "noreferrer" : undefined}>
  <span class="pill-button__label block h-[1.2em] overflow-hidden leading-control">
    <span class="pill-button__label-track flex h-[200%] flex-col">
      <span class="pill-button__label-copy flex flex-[0_0_50%] items-center whitespace-nowrap"><slot /></span>
      <span class="pill-button__label-copy flex flex-[0_0_50%] items-center whitespace-nowrap" aria-hidden="true"><slot /></span>
    </span>
  </span>
  <span class="pill-button__icon relative size-[var(--control-icon-size)] flex-none overflow-hidden rounded-pill bg-white text-ink" aria-hidden="true">
    <Icon name="arrow-right" class="pill-button__arrow pill-button__arrow--right absolute inset-[7px] size-[18px] rounded-none bg-transparent p-0 opacity-100" />
    <Icon name="arrow-up-right" class="pill-button__arrow pill-button__arrow--up-right absolute inset-[7px] size-[18px] rounded-none bg-transparent p-0 opacity-0 [transform:translate(-6px,6px)_scale(.8)]" />
  </span>
</a>
