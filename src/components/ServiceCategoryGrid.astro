---
import { Bot, Megaphone, MonitorSmartphone, SearchCheck } from "@lucide/astro";
import Icon from "@/components/Icon.astro";
import Reveal from "@/components/Reveal.astro";
import type { ServiceEntry } from "@/lib/content";
import { localizePath, type Locale } from "@/lib/i18n";
import { localizedCategoryDescription, localizedCategoryTitle, serviceCategories } from "@/lib/services";

interface Props { locale: Locale; services?: ServiceEntry[]; compact?: boolean; }
const { locale, services = [], compact = false } = Astro.props;
const icons = { design: MonitorSmartphone, search: SearchCheck, campaign: Megaphone, automation: Bot };
const bySlug = new Map(services.map((service) => [service.data.slug, service]));
---
<div class:list={["service-category-grid", { "service-category-grid--compact": compact }]}>
  {serviceCategories.map((category, index) => {
    const CategoryIcon = icons[category.icon];
    const categoryServices = category.services.map((slug) => bySlug.get(slug)).filter(Boolean) as ServiceEntry[];
    const title = localizedCategoryTitle(category, locale);
    const exploreLabel = locale === "de" ? `${title} entdecken` : `Explore ${title}`;
    return <Reveal delay={index * 50}><article class={`service-category service-category--${category.id}`}>
      <a class="service-category-main" href={localizePath(category.href, locale)}>
        <CategoryIcon class="service-category-icon" aria-hidden="true" />
        <span class="service-category-copy"><strong>{title}</strong><small>{localizedCategoryDescription(category, locale)}</small></span>
        <span class="service-category-cta">
          <span class="service-category-cta-label">
            <span class="service-category-cta-label-track">
              <span>{exploreLabel}</span>
              <span aria-hidden="true">{exploreLabel}</span>
            </span>
          </span>
          <span class="service-category-cta-arrow-box" aria-hidden="true">
            <Icon name="arrow-right" class="service-category-cta-arrow service-category-cta-arrow--right" />
            <Icon name="arrow-up-right" class="service-category-cta-arrow service-category-cta-arrow--up-right" />
          </span>
        </span>
      </a>
      {categoryServices.length > 0 && <nav class="service-category-links" aria-label={title}>
        {categoryServices.map((service) => <a href={localizePath(`/services/${service.data.slug}`, locale)}>{service.data.title}<span aria-hidden="true">→</span></a>)}
      </nav>}
    </article></Reveal>;
  })}
</div>
