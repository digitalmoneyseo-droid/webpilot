---
interface Props { title: string; eyebrow?: string; copy?: string; align?: "left" | "center"; }
const { title, eyebrow, copy, align = "left" } = Astro.props;
---
<div class:list={["section-heading", { "section-heading--center": align === "center" }]}>
  {eyebrow && <span class="eyebrow">{eyebrow}</span>}
  <h2>{title}</h2>
  {copy && <p>{copy}</p>}
</div>
