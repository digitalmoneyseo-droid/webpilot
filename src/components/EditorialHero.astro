---
interface Props { title: string; copy?: string; }
const { title, copy } = Astro.props;
---
<section class="editorial-hero grid min-h-0 [place-content:start_center] [place-items:start_center] px-page pt-[var(--page-title-top)] pb-16 max-[600px]:pt-26 max-[600px]:pb-12">
  <div class="editorial-hero-grid flex w-full max-w-[58rem] flex-col items-center gap-4 text-center max-[900px]:gap-6">
    <h1 class="m-0 mx-auto w-full max-w-[48rem] text-display-lg font-bold text-balance">{title}</h1>
    {copy && <p class="mx-auto max-w-[48rem] text-lead font-medium text-muted text-balance">{copy}</p>}
  </div>
</section>
