---
interface Props { eyebrow: string; title: string; copy?: string; index?: string; }
const { eyebrow, title, copy, index } = Astro.props;
---
<section class="editorial-hero">
  <div class="editorial-meta"><span>{index}</span><span>{eyebrow}</span></div>
  <div class="editorial-hero-grid"><h1>{title}</h1>{copy && <p>{copy}</p>}</div>
</section>
