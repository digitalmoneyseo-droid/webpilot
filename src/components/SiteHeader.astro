---
import BrandMark from "@/components/BrandMark.astro";
import Icon from "@/components/Icon.astro";
import { alternatePath, localizePath, studioLocation, t, type Locale } from "@/lib/i18n";
import { localizedCategoryTitle, serviceCategories } from "@/lib/services";
interface Props { locale: Locale; pathname: string; }
const { locale, pathname } = Astro.props;
const otherLocale: Locale = locale === "de" ? "en" : "de";
const isActive = (href: string) => {
  const localizedHref = localizePath(href, locale);
  return pathname === localizedHref || pathname.startsWith(`${localizedHref}/`);
};
---
<header class="site-header fixed top-[22px] left-1/2 z-50 flex w-max items-center gap-2 [transform:translateX(-50%)] max-[900px]:left-[15px] max-[900px]:[transform:none]">
  <a href={localizePath("/", locale)} class="header-mark inline-flex h-11 w-auto items-center justify-center rounded-[12px] border-0 bg-white px-[17px] shadow-surface" aria-label={t(locale, "Webpilot home")}><BrandMark /></a>
  <nav class="desktop-nav relative inline-flex h-11 items-center justify-center gap-px rounded-[12px] border-0 bg-white p-1 shadow-surface max-[900px]:hidden" aria-label={t(locale, "Main navigation")}>
    <span class="desktop-nav-indicator pointer-events-none absolute top-1 bottom-1 left-0 rounded-lg bg-[#f1f1ee] opacity-0" aria-hidden="true"></span>
    <a href={localizePath("/work", locale)} class:list={["relative z-1 inline-flex h-9 items-center rounded-lg px-3.5 text-control font-medium text-[#696965]", { "is-active": isActive("/work") }]} aria-current={isActive("/work") ? "page" : undefined}>{t(locale, "Work")}</a>
    <div class="desktop-services static h-9">
      <button type="button" class:list={["desktop-services-trigger relative z-1 inline-flex h-9 cursor-pointer list-none items-center gap-[5px] rounded-lg border-0 bg-transparent px-3 text-control font-medium text-[#696965]", { "is-active": isActive("/services") }]} aria-haspopup="true" aria-expanded="false" aria-controls="desktop-services-menu"><span>{t(locale, "Services")}</span><Icon name="chevron-down" class="w-3.5" /></button>
      <div id="desktop-services-menu" class="desktop-megamenu invisible pointer-events-none absolute top-[52px] left-0 w-full rounded-[12px] border-0 bg-white p-1 opacity-0 shadow-surface [transform:translateY(-8px)]" aria-hidden="true">
        <div class="megamenu-list p-0">
          {serviceCategories.map((category) => <a class="relative grid min-h-11 grid-cols-[minmax(0,1fr)_auto] items-center gap-3 rounded-lg px-3 py-2 text-[#696965]" href={localizePath(category.href, locale)} aria-label={localizedCategoryTitle(category, locale)}>
              <span class="megamenu-label block h-[1.2em] overflow-hidden leading-control">
                <span class="megamenu-label-track flex h-[200%] flex-col">
                  <strong class="flex flex-[0_0_50%] items-center whitespace-nowrap text-control font-medium">{localizedCategoryTitle(category, locale)}</strong>
                  <strong class="flex flex-[0_0_50%] items-center whitespace-nowrap text-control font-medium" aria-hidden="true">{localizedCategoryTitle(category, locale)}</strong>
                </span>
              </span>
              <span class="megamenu-arrow-box relative h-7 w-7 overflow-hidden rounded-none" aria-hidden="true">
                <Icon name="arrow-right" class="megamenu-arrow megamenu-arrow--right absolute inset-[5px] h-[18px] w-[18px] opacity-100" />
                <Icon name="arrow-up-right" class="megamenu-arrow megamenu-arrow--up-right absolute inset-[5px] h-[18px] w-[18px] opacity-0 [transform:translate(-6px,6px)_scale(.8)]" />
              </span>
            </a>)}
        </div>
      </div>
    </div>
    <a href={localizePath("/about", locale)} class:list={["relative z-1 inline-flex h-9 items-center rounded-lg px-3.5 text-control font-medium text-[#696965]", { "is-active": isActive("/about") }]} aria-current={isActive("/about") ? "page" : undefined}>{t(locale, "About")}</a>
    <a href={localizePath("/contact", locale)} class:list={["relative z-1 inline-flex h-9 items-center rounded-lg px-3.5 text-control font-medium text-[#696965]", { "is-active": isActive("/contact") }]} aria-current={isActive("/contact") ? "page" : undefined}>{t(locale, "Contact")}</a>
  </nav>
  <a class="header-language inline-flex h-11 cursor-pointer items-center justify-center gap-[7px] rounded-[12px] border-0 bg-white px-3 text-control font-medium text-[#73736f] shadow-surface max-[900px]:fixed max-[900px]:top-[22px] max-[900px]:right-[65px]" href={alternatePath(pathname, otherLocale)} aria-label={locale === "de" ? "Switch to English" : "Auf Deutsch wechseln"}>
    <span class="header-language__icon-box relative h-[19px] w-[19px] flex-none overflow-hidden rounded-none text-[#111]" aria-hidden="true">
      <Icon name="translate" class="header-language__icon header-language__icon--out absolute inset-0 m-0 h-[19px] w-[19px] opacity-100" />
      <Icon name="translate" class="header-language__icon header-language__icon--in absolute inset-0 m-0 h-[19px] w-[19px] opacity-0 [transform:translate(-6px,6px)_scale(.8)]" />
    </span>
    <span class="header-language__label block h-[1.2em] overflow-hidden leading-control">
      <span class="header-language__label-track flex h-[200%] flex-col">
        <span class="header-language__row flex flex-[0_0_50%] items-center gap-[3px] whitespace-nowrap"><span class:list={{ "is-active": locale === "de" }}>DE</span><i class="not-italic text-[#c3c3be]">/</i><span class:list={{ "is-active": locale === "en" }}>EN</span></span>
        <span class="header-language__row flex flex-[0_0_50%] items-center gap-[3px] whitespace-nowrap" aria-hidden="true"><span class:list={{ "is-active": locale === "de" }}>DE</span><i class="not-italic text-[#c3c3be]">/</i><span class:list={{ "is-active": locale === "en" }}>EN</span></span>
      </span>
    </span>
  </a>
  <button class="header-menu fixed top-[22px] right-[22px] left-auto m-0 inline-flex h-11 w-11 cursor-pointer items-center justify-center rounded-[12px] border-0 bg-white p-0 shadow-surface min-[901px]:hidden max-[900px]:right-[15px] max-[600px]:w-[42px] max-[600px]:[&_span]:hidden" type="button" aria-label={t(locale, "Open navigation")} aria-expanded="false" aria-controls="site-menu"><Icon name="menu" class="w-[17px]" /></button>
</header>

<div id="site-menu" class="menu-overlay invisible fixed inset-0 z-100 flex flex-col bg-[#101010] px-[clamp(24px,5vw,76px)] pt-6 pb-[34px] text-white opacity-0 [transform:translateY(-12px)] min-[901px]:hidden max-[900px]:overflow-y-auto max-[600px]:px-[18px] max-[600px]:pt-4 max-[600px]:pb-6" aria-hidden="true" inert role="dialog" aria-modal="true" aria-label={t(locale, "Site navigation")}>
  <div class="menu-top flex items-center justify-between">
    <a href={localizePath("/", locale)} class="menu-brand fixed top-[22px] left-[22px] z-2 inline-flex h-11 items-center rounded-[12px] bg-[#101010] px-[17px] shadow-dark-surface max-[900px]:left-[15px]"><BrandMark inverse /></a>
    <a class="header-language menu-language fixed top-[22px] right-[74px] z-2 inline-flex h-11 cursor-pointer items-center justify-center gap-[7px] rounded-[12px] border-0 bg-transparent px-3 text-control font-medium text-white shadow-dark-surface max-[900px]:right-[67px]" href={alternatePath(pathname, otherLocale)} aria-label={locale === "de" ? "Switch to English" : "Auf Deutsch wechseln"}>
      <span class="header-language__icon-box relative h-[19px] w-[19px] flex-none overflow-hidden rounded-none text-white" aria-hidden="true">
        <Icon name="translate" class="header-language__icon header-language__icon--out absolute inset-0 m-0 h-[19px] w-[19px] opacity-100" />
        <Icon name="translate" class="header-language__icon header-language__icon--in absolute inset-0 m-0 h-[19px] w-[19px] opacity-0 [transform:translate(-6px,6px)_scale(.8)]" />
      </span>
      <span class="header-language__label block h-[1.2em] overflow-hidden leading-control">
        <span class="header-language__label-track flex h-[200%] flex-col">
          <span class="header-language__row flex flex-[0_0_50%] items-center gap-[3px] whitespace-nowrap"><span class:list={{ "is-active": locale === "de" }}>DE</span><i class="not-italic text-white/50">/</i><span class:list={{ "is-active": locale === "en" }}>EN</span></span>
          <span class="header-language__row flex flex-[0_0_50%] items-center gap-[3px] whitespace-nowrap" aria-hidden="true"><span class:list={{ "is-active": locale === "de" }}>DE</span><i class="not-italic text-white/50">/</i><span class:list={{ "is-active": locale === "en" }}>EN</span></span>
        </span>
      </span>
    </a>
    <button type="button" class="menu-close fixed top-[22px] right-[22px] z-2 grid h-11 w-11 cursor-pointer place-items-center rounded-[12px] border-0 bg-transparent text-white shadow-dark-surface max-[900px]:right-[15px]" aria-label={t(locale, "Close navigation")}><Icon name="plus" class="w-[19px] [transform:rotate(45deg)]" /></button>
  </div>
  <nav class="menu-links my-auto flex flex-col self-stretch max-[900px]:w-full max-[900px]:max-w-[44rem]" aria-label={t(locale, "Main navigation")}>
    <a class="grid grid-cols-[64px_1fr_54px] items-center border-b border-white/13 py-2.5 text-heading-md font-medium max-[900px]:min-h-18 max-[900px]:max-h-20 max-[900px]:w-full max-[900px]:grid-cols-[3rem_minmax(0,1fr)_2rem] max-[900px]:border-0 max-[900px]:border-b max-[900px]:px-0 max-[900px]:py-[.65rem] max-[600px]:grid-cols-[2rem_minmax(0,1fr)_1.5rem]" href={localizePath("/work", locale)} tabindex="-1"><span class="justify-self-start text-caption tabular-nums text-[#929292]">01</span><b class="justify-self-start font-medium text-left">{t(locale, "Work")}</b><Icon name="arrow-up-right" class="w-6 justify-self-end" /></a>
    <div class="menu-services">
      <button type="button" class="menu-services-trigger grid grid-cols-[64px_1fr_54px] items-center border-0 border-b border-white/13 bg-transparent py-2.5 text-left text-heading-md font-medium text-white max-[900px]:min-h-18 max-[900px]:max-h-20 max-[900px]:w-full max-[900px]:cursor-pointer max-[900px]:grid-cols-[3rem_minmax(0,1fr)_2rem] max-[900px]:px-0 max-[900px]:py-[.65rem] max-[600px]:grid-cols-[2rem_minmax(0,1fr)_1.5rem]" aria-expanded="false" aria-controls="mobile-service-list" tabindex="-1"><span class="justify-self-start text-caption tabular-nums text-[#929292]">02</span><b class="justify-self-start font-medium text-left">{t(locale, "Services")}</b><Icon name="plus" class="w-6 justify-self-end" /></button>
      <div id="mobile-service-list" class="menu-service-list opacity-0 [transform:translateY(-8px)]" aria-hidden="true"><div class="flex flex-col px-8 pl-12 max-[600px]:pr-6 max-[600px]:pl-8">
        {serviceCategories.map((category) => <a class="grid grid-cols-[minmax(0,1fr)_1.5rem] items-center gap-4 rounded-none border-0 border-b border-white/13 px-0 py-3.5 text-left text-body opacity-0 [transform:translateY(.5rem)] last:border-b-0" href={localizePath(category.href, locale)} tabindex="-1"><strong class="font-semibold">{localizedCategoryTitle(category, locale)}</strong><Icon name="arrow-up-right" class="w-4 justify-self-end" /></a>)}
      </div></div>
    </div>
    <a class="grid grid-cols-[64px_1fr_54px] items-center border-b border-white/13 py-2.5 text-heading-md font-medium max-[900px]:min-h-18 max-[900px]:max-h-20 max-[900px]:w-full max-[900px]:grid-cols-[3rem_minmax(0,1fr)_2rem] max-[900px]:border-0 max-[900px]:border-b max-[900px]:px-0 max-[900px]:py-[.65rem] max-[600px]:grid-cols-[2rem_minmax(0,1fr)_1.5rem]" href={localizePath("/about", locale)} tabindex="-1"><span class="justify-self-start text-caption tabular-nums text-[#929292]">03</span><b class="justify-self-start font-medium text-left">{t(locale, "About")}</b><Icon name="arrow-up-right" class="w-6 justify-self-end" /></a>
    <a class="grid grid-cols-[64px_1fr_54px] items-center border-b border-white/13 py-2.5 text-heading-md font-medium max-[900px]:min-h-18 max-[900px]:max-h-20 max-[900px]:w-full max-[900px]:grid-cols-[3rem_minmax(0,1fr)_2rem] max-[900px]:border-0 max-[900px]:border-b-0 max-[900px]:px-0 max-[900px]:py-[.65rem] max-[600px]:grid-cols-[2rem_minmax(0,1fr)_1.5rem]" href={localizePath("/contact", locale)} tabindex="-1"><span class="justify-self-start text-caption tabular-nums text-[#929292]">04</span><b class="justify-self-start font-medium text-left">{t(locale, "Contact")}</b><Icon name="arrow-up-right" class="w-6 justify-self-end" /></a>
  </nav>
  <div class="menu-bottom flex items-center justify-between text-caption text-[#9a9a9a] max-[900px]:gap-5 max-[600px]:flex-col max-[600px]:items-start"><span>{studioLocation(locale)}</span><a href="mailto:hello@webpilot.studio">hello@webpilot.studio</a></div>
</div>

<script>
  import { initNavigation } from "@/browser/navigation";
  let cleanupNavigation: (() => void) | undefined;
  const initializeNavigation = () => {
    cleanupNavigation?.();
    cleanupNavigation = initNavigation();
  };
  document.addEventListener("astro:page-load", initializeNavigation);
  document.addEventListener("astro:before-swap", () => cleanupNavigation?.());
</script>
