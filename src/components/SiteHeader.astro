---
import BrandMark from "@/components/BrandMark.astro";
import Icon from "@/components/Icon.astro";
import { alternatePath, localizePath, t, type Locale } from "@/lib/i18n";
import { localizedCategoryTitle, serviceCategories } from "@/lib/services";
interface Props { locale: Locale; pathname: string; }
const { locale, pathname } = Astro.props;
const otherLocale: Locale = locale === "de" ? "en" : "de";
const isActive = (href: string) => {
  const localizedHref = localizePath(href, locale);
  return pathname === localizedHref || pathname.startsWith(`${localizedHref}/`);
};
---
<header class="site-header">
  <a href={localizePath("/", locale)} class="header-mark" aria-label={t(locale, "Webpilot home")}><BrandMark /></a>
  <nav class="desktop-nav" aria-label={t(locale, "Main navigation")}>
    <a href={localizePath("/work", locale)} class:list={{ "is-active": isActive("/work") }} aria-current={isActive("/work") ? "page" : undefined}>{t(locale, "Work")}</a>
    <div class="desktop-services">
      <button type="button" class:list={["desktop-services-trigger", { "is-active": isActive("/services") }]} aria-haspopup="true" aria-expanded="false" aria-controls="desktop-services-menu"><span>{t(locale, "Services")}</span><Icon name="chevron-down" /></button>
      <div id="desktop-services-menu" class="desktop-megamenu" aria-hidden="true">
        <div class="megamenu-list">
          {serviceCategories.map((category) => <a href={localizePath(category.href, locale)} aria-label={localizedCategoryTitle(category, locale)}>
              <span class="megamenu-label">
                <span class="megamenu-label-track">
                  <strong>{localizedCategoryTitle(category, locale)}</strong>
                  <strong aria-hidden="true">{localizedCategoryTitle(category, locale)}</strong>
                </span>
              </span>
              <span class="megamenu-arrow-box" aria-hidden="true">
                <Icon name="arrow-right" class="megamenu-arrow megamenu-arrow--right" />
                <Icon name="arrow-up-right" class="megamenu-arrow megamenu-arrow--up-right" />
              </span>
            </a>)}
        </div>
      </div>
    </div>
    <a href={localizePath("/about", locale)} class:list={{ "is-active": isActive("/about") }} aria-current={isActive("/about") ? "page" : undefined}>{t(locale, "About")}</a>
    <a href={localizePath("/contact", locale)} class:list={{ "is-active": isActive("/contact") }} aria-current={isActive("/contact") ? "page" : undefined}>{t(locale, "Contact")}</a>
  </nav>
  <a class="header-language" href={alternatePath(pathname, otherLocale)} aria-label={locale === "de" ? "Switch to English" : "Auf Deutsch wechseln"}>
    <span class="header-language__icon-box" aria-hidden="true">
      <Icon name="translate" class="header-language__icon header-language__icon--out" />
      <Icon name="translate" class="header-language__icon header-language__icon--in" />
    </span>
    <span class="header-language__label">
      <span class="header-language__label-track">
        <span class="header-language__row"><span class:list={{ "is-active": locale === "de" }}>DE</span><i>/</i><span class:list={{ "is-active": locale === "en" }}>EN</span></span>
        <span class="header-language__row" aria-hidden="true"><span class:list={{ "is-active": locale === "de" }}>DE</span><i>/</i><span class:list={{ "is-active": locale === "en" }}>EN</span></span>
      </span>
    </span>
  </a>
  <button class="header-menu" type="button" aria-label={t(locale, "Open navigation")} aria-expanded="false" aria-controls="site-menu"><Icon name="menu" /></button>
</header>

<div id="site-menu" class="menu-overlay" aria-hidden="true" inert role="dialog" aria-modal="true" aria-label={t(locale, "Site navigation")}>
  <div class="menu-top">
    <a href={localizePath("/", locale)} class="menu-brand"><BrandMark inverse /></a>
    <button type="button" class="menu-close" aria-label={t(locale, "Close navigation")}><Icon name="plus" /></button>
  </div>
  <nav class="menu-links" aria-label={t(locale, "Main navigation")}>
    <a href={localizePath("/work", locale)} tabindex="-1"><span>01</span><b>{t(locale, "Work")}</b><Icon name="arrow-up-right" /></a>
    <div class="menu-services">
      <button type="button" class="menu-services-trigger" aria-expanded="false" aria-controls="mobile-service-list" tabindex="-1"><span>02</span><b>{t(locale, "Services")}</b><Icon name="plus" /></button>
      <div id="mobile-service-list" class="menu-service-list" aria-hidden="true"><div>
        {serviceCategories.map((category) => <a href={localizePath(category.href, locale)} tabindex="-1"><strong>{localizedCategoryTitle(category, locale)}</strong><Icon name="arrow-up-right" /></a>)}
      </div></div>
    </div>
    <a href={localizePath("/about", locale)} tabindex="-1"><span>03</span><b>{t(locale, "About")}</b><Icon name="arrow-up-right" /></a>
    <a href={localizePath("/contact", locale)} tabindex="-1"><span>04</span><b>{t(locale, "Contact")}</b><Icon name="arrow-up-right" /></a>
  </nav>
  <div class="menu-bottom"><span>{t(locale, "Berlin · Working worldwide")}</span><a href="mailto:hello@webpilot.studio">hello@webpilot.studio</a></div>
</div>

<script>
  import { initNavigation } from "@/browser/navigation";
  initNavigation();
</script>
