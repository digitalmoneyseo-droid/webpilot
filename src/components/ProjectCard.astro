---
import Icon from "@/components/Icon.astro";
import ProjectVisual from "@/components/ProjectVisual.astro";
import type { ProjectEntry } from "@/lib/content";
import { localizePath, type Locale } from "@/lib/i18n";
interface Props { project: ProjectEntry["data"]; locale: Locale; decorative?: boolean; filterable?: boolean; filterCategories?: string[]; hidden?: boolean; }
const { project, locale, decorative = false, filterable = false, filterCategories = project.categories, hidden = false } = Astro.props;
---
<a href={localizePath(`/work/${project.slug}`, locale)} class="project-card" aria-hidden={decorative ? "true" : undefined} tabindex={decorative ? -1 : undefined} data-project={filterable ? "" : undefined} data-categories={filterable ? JSON.stringify(filterCategories) : undefined} hidden={hidden}>
  <div class="project-card-top"><span>{project.categories[0]}</span><span>{project.year}</span></div>
  <ProjectVisual project={project} />
  <div class="project-card-copy"><div><h3>{project.title}</h3><p>{project.summary}</p></div><span class="round-arrow"><Icon name="arrow-up-right" /></span></div>
</a>
