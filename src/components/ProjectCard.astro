---
import Icon from "@/components/Icon.astro";
import ProjectVisual from "@/components/ProjectVisual.astro";
import type { ProjectEntry } from "@/lib/content";
import { localizePath, type Locale } from "@/lib/i18n";
interface Props { project: ProjectEntry["data"]; locale: Locale; decorative?: boolean; filterable?: boolean; filterCategories?: string[]; hidden?: boolean; }
const { project, locale, decorative = false, filterable = false, filterCategories = project.categories, hidden = false } = Astro.props;
---
<a href={localizePath(`/work/${project.slug}`, locale)} class="project-card group relative isolate flex min-h-[520px] flex-col overflow-hidden rounded-card bg-surface shadow-surface hover:shadow-surface-hover [.work-ribbon_&]:h-auto [.work-ribbon_&]:min-h-0 [.work-ribbon_&]:w-[530px] [.work-ribbon_&]:flex-none [.work-ribbon_&]:aspect-[530/425] max-[900px]:[.work-ribbon_&]:w-[min(82vw,440px)] max-[900px]:[.work-ribbon_&]:aspect-3/2 max-[600px]:[.work-ribbon_&]:w-[min(calc(100vw-32px),360px)] max-[600px]:[.work-ribbon_&]:aspect-4/3" aria-hidden={decorative ? "true" : undefined} tabindex={decorative ? -1 : undefined} data-project={filterable ? "" : undefined} data-categories={filterable ? JSON.stringify(filterCategories) : undefined} hidden={hidden}>
  <div class="project-card-top absolute inset-x-3.5 top-3.5 z-5 flex justify-between text-caption"><span class="rounded-[max(0px,calc(var(--radius)-14px))] bg-white/84 px-2.25 py-1.5 backdrop-blur-[10px]">{project.categories[0]}</span><span class="rounded-[max(0px,calc(var(--radius)-14px))] bg-white/84 px-2.25 py-1.5 backdrop-blur-[10px]">{project.year}</span></div>
  <ProjectVisual project={project} />
  <div class="project-card-copy flex min-h-30 items-center justify-between gap-4 bg-surface p-5 [.work-ribbon_&]:hidden"><div><h3 class="m-0 mb-2 text-heading-sm font-semibold">{project.title}</h3><p class="m-0 text-small text-[#777]">{project.summary}</p></div><span class="round-arrow relative grid size-10 flex-none place-items-center overflow-hidden rounded-full border-0 shadow-surface group-hover:bg-[#111] group-hover:text-white group-hover:shadow-dark-surface" aria-hidden="true"><Icon name="arrow-right" class="round-arrow__icon round-arrow__icon--right absolute inset-[11px] size-[18px]" /><Icon name="arrow-up-right" class="round-arrow__icon round-arrow__icon--up-right absolute inset-[11px] size-[18px]" /></span></div>
</a>
