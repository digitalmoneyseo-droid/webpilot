---
import BrandMark from "@/components/BrandMark.astro";
import { localizePath, t, type Locale } from "@/lib/i18n";
interface Props { locale: Locale; }
const { locale } = Astro.props;
const conceptPath = locale === "de" ? "/konzept" : "/concept";
---
<footer class="site-footer">
  <div class="footer-main"><a href={localizePath("/", locale)} class="footer-brand"><BrandMark /><span>Webpilot</span></a><div class="footer-links"><div><span>{t(locale, "Explore")}</span><a href={localizePath("/work", locale)}>{t(locale, "Work")}</a><a href={localizePath("/services", locale)}>{t(locale, "Services")}</a><a href={localizePath("/about", locale)}>{t(locale, "About")}</a></div><div><span>{t(locale, "Connect")}</span><a href={localizePath("/insights", locale)}>{t(locale, "Insights")}</a><a href={localizePath("/contact", locale)}>{t(locale, "Contact")}</a><a href="mailto:hello@webpilot.studio">{t(locale, "Email")}</a></div><div><span>{locale === "de" ? "Rechtliches" : "Legal"}</span><a href={localizePath(conceptPath, locale)}>{locale === "de" ? "Konzept-Hinweis" : "Concept notice"}</a><a href={localizePath("/privacy", locale)}>{locale === "de" ? "Datenschutz" : "Privacy"}</a><a href={localizePath("/imprint", locale)}>{locale === "de" ? "Impressum" : "Imprint"}</a></div></div></div>
  <div class="footer-legal"><span>© 2026 Webpilot Studio</span><a href={localizePath(conceptPath, locale)}>{locale === "de" ? "Konzept-Website · Fiktive Beispiele" : "Concept website · Fictional examples"}</a><span>{locale === "de" ? "Sitz in Deutschland · Weltweit tätig" : "Based in Germany · Operating worldwide"}</span></div>
</footer>
