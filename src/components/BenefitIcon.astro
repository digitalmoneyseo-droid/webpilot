---
import { BadgeCheck, Blend, ChartNoAxesCombined, Handshake, Network, RefreshCw, Target, Waypoints } from "@lucide/astro";

interface Props { name: "outcome" | "senior" | "system" | "ownership" | "creative-tech" | "connected" | "outcomes" | "optimized"; }

const { name } = Astro.props;
// Maintained source icons from Lucide: https://lucide.dev/icons/
const icons = {
  outcome: Target,
  senior: BadgeCheck,
  system: Waypoints,
  ownership: Handshake,
  "creative-tech": Blend,
  connected: Network,
  outcomes: ChartNoAxesCombined,
  optimized: RefreshCw,
};
const BenefitIcon = icons[name];
---
<BenefitIcon aria-hidden="true" stroke-width={1.7} />
