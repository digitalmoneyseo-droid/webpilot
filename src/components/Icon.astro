---
interface Props { name: "arrow-up-right" | "arrow-right" | "plus" | "chevron-down" | "menu" | "translate"; class?: string; }
const { name, class: className } = Astro.props;
---
<svg viewBox="0 0 20 20" fill="none" aria-hidden="true" class={className}>
  {name === "arrow-up-right" && <path d="M5.5 14.5 14 6m-6.5 0H14v6.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />}
  {name === "arrow-right" && <path d="M3.5 10h13m-4.5-4.5 4.5 4.5-4.5 4.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />}
  {name === "plus" && <path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />}
  {name === "chevron-down" && <path d="m5.5 7.5 4.5 4.5 4.5-4.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />}
  {name === "menu" && <path d="M4 7h12M4 13h12" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />}
  {name === "translate" && <path d="M3.5 4.5h8M7.5 3v1.5m-2.8 3h5.6M5.3 4.5c.4 3.1 2.4 5.4 5.2 6.6M10.1 4.5c-.4 3.1-2.4 5.4-5.2 6.6M11.5 16.5l2.8-7 2.8 7m-4.7-2.1h3.8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" />}
</svg>
