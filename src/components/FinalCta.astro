---
import CtaButton from "@/components/CtaButton.astro";
import { localizePath, t, type Locale } from "@/lib/i18n";
interface Props { locale: Locale; }
const { locale } = Astro.props;
---
<section class="final-cta"><h2>{locale === "de" ? "Bereit für mehr" : "Ready to"}<br />{locale === "de" ? "Wachstum?" : "grow?"}</h2><p>{locale === "de" ? "Wir verbinden Marke, Technik, Marketing und KI für messbare Ergebnisse." : "We join brand, tech, marketing, and AI to drive clear results."}</p><CtaButton href={localizePath("/contact", locale)} light>{t(locale, "Book strategy call")}</CtaButton></section>
