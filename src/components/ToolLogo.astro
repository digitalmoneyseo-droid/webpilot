---
interface Props { name: string; }
const { name } = Astro.props;
---
<svg class="tool-logo" viewBox="0 0 24 24" aria-hidden="true">
  {name === "Figma" && <><path d="M8 2h4v7H8a3.5 3.5 0 1 1 0-7Z" /><path d="M12 2h4a3.5 3.5 0 1 1 0 7h-4V2Z" /><path d="M8 9h4v7H8a3.5 3.5 0 1 1 0-7Z" /><circle cx="15.5" cy="12.5" r="3.5" /><path d="M8 16h4v3.5A3.5 3.5 0 1 1 8 16Z" /></>}
  {name === "Framer" && <path d="M5 2h14v7H12l7 7h-7v6l-7-7h7L5 8V2Z" />}
  {name === "Webflow" && <path d="M2 7h4l2 7 3-7h3l2 7 2-7h4l-4 11h-4l-2-5-2 5H6L2 7Z" />}
  {name === "Astro" && <><path d="M7.5 18 12 3l4.5 15-2.8-3H10.3l-2.8 3Z" /><path d="M9 19c1.7 1.1 4.3 1.1 6 0-.4 2-1.4 3-3 3s-2.6-1-3-3Z" /></>}
  {name === "TypeScript" && <><rect x="2" y="2" width="20" height="20" rx="2" /><text x="5.2" y="17" class="tool-logo-text tool-logo-text--light">TS</text></>}
  {name === "Tailwind CSS" && <><path d="M3 10c2.5-4 5.5-4 9 0 2 2.3 4 2.3 6 0 1-1.1 2-1.6 3-1.6-2.5 4-5.5 4-9 0-2-2.3-4-2.3-6 0-1 1.1-2 1.6-3 1.6Z" /><path d="M3 16c2.5-4 5.5-4 9 0 2 2.3 4 2.3 6 0 1-1.1 2-1.6 3-1.6-2.5 4-5.5 4-9 0-2-2.3-4-2.3-6 0-1 1.1-2 1.6-3 1.6Z" /></>}
  {name === "Shopify" && <><path d="m5 7 3-1c.5-2.6 1.8-4 3.7-4 1.5 0 2.5 1 3 2.8L18 6l1 15-14-2V7Z" /><text x="8" y="16" class="tool-logo-text tool-logo-text--light">S</text></>}
  {name === "WordPress" && <><circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="1.8" /><text x="5.4" y="17" class="tool-logo-text">W</text></>}
  {name === "After Effects" && <><rect x="2" y="3" width="20" height="18" rx="4" /><text x="4.7" y="17" class="tool-logo-text tool-logo-text--light">Ae</text></>}
  {name === "Rive" && <><path d="M5 3h8.5a5.5 5.5 0 0 1 0 11H9v7H5V3Zm4 4v3h4.2a1.5 1.5 0 1 0 0-3H9Z" /><path d="m13 13 6 8h-5l-5-7" /></>}
  {name === "Lottie" && <><circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="2" /><path d="M6 14c3-5 7-6 12-4M8 18c3-4 6-5 10-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></>}
  {name === "OpenAI" && <><circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="2" /><path d="M12 2a5 5 0 0 1 4.5 2.8A5 5 0 0 1 21 10a5 5 0 0 1-1.5 7A5 5 0 0 1 12 22a5 5 0 0 1-6.5-5A5 5 0 0 1 3 10a5 5 0 0 1 4.5-5.2A5 5 0 0 1 12 2Z" fill="none" stroke="currentColor" stroke-width="1.8" /></>}
  {name === "Make" && <><path d="m3 12 5-5 5 5-5 5-5-5Zm8 0 5-5 5 5-5 5-5-5Z" /><circle cx="12" cy="12" r="2.2" fill="var(--bg)" /></>}
  {name === "n8n" && <><path d="M4 17 9 8l6 8 5-10M9 8l11 5" fill="none" stroke="currentColor" stroke-width="1.8" /><circle cx="4" cy="17" r="2" /><circle cx="9" cy="8" r="2" /><circle cx="15" cy="16" r="2" /><circle cx="20" cy="6" r="2" /><circle cx="20" cy="13" r="2" /></>}
</svg>
