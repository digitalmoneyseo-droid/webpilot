---
import "@fontsource/bebas-neue/latin-400.css";
import "@/styles/global.css";
import "@/styles/design-system.css";
import SiteHeader from "@/components/SiteHeader.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import { getLegalOperator } from "@/config/legal";
import { absoluteUrl, analyticsEnabled, robotsDirective } from "@/lib/site";
import { alternatePath, type Locale } from "@/lib/i18n";

interface Props {
  locale: Locale;
  title?: string;
  description: string;
  indexable?: boolean;
  image?: string;
  article?: boolean;
  hideFooter?: boolean;
  structuredData?: Record<string, unknown>[];
}

const { locale, title, description, indexable = true, image = "/social-card.png", article = false, hideFooter = false, structuredData = [] } = Astro.props;
const pathname = Astro.url.pathname;
const pageTitle = title ? `${title} — Webpilot` : "Webpilot — Growth and technology studio";
const canonical = absoluteUrl(pathname);
const analyticsToken = import.meta.env.PUBLIC_CLOUDFLARE_ANALYTICS_TOKEN;
const operator = getLegalOperator();
const schemas: Record<string, unknown>[] = [...structuredData];
if (operator) schemas.unshift({
  "@context": "https://schema.org", "@type": ["Organization", "ProfessionalService"], name: operator.legalName,
  url: absoluteUrl("/"), email: operator.email,
  address: { "@type": "PostalAddress", streetAddress: operator.streetAddress, postalCode: operator.postalCode, addressLocality: operator.city, addressCountry: operator.country },
});
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content={robotsDirective(indexable)} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="de" href={absoluteUrl(alternatePath(pathname, "de"))} />
    <link rel="alternate" hreflang="en" href={absoluteUrl(alternatePath(pathname, "en"))} />
    <link rel="alternate" hreflang="x-default" href={absoluteUrl(alternatePath(pathname, "de"))} />
    <link rel="icon" href="/icon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32x32.png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta property="og:type" content={article ? "article" : "website"} />
    <meta property="og:site_name" content="Webpilot" />
    <meta property="og:locale" content={locale === "de" ? "de_DE" : "en_US"} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={absoluteUrl(image)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteUrl(image)} />
    <title>{pageTitle}</title>
    <script>document.documentElement.classList.add("reveal-ready");</script>
    {schemas.map((schema) => <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)}></script>)}
  </head>
  <body>
    <a class="skip-link" href="#main-content">{locale === "de" ? "Zum Inhalt springen" : "Skip to content"}</a>
    <SiteHeader {locale} {pathname} />
    <slot />
    {!hideFooter && <SiteFooter {locale} />}
    <script>
      const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const reveals = [...document.querySelectorAll<HTMLElement>("[data-reveal]")];
      if (reducedMotion || !("IntersectionObserver" in window)) reveals.forEach((element) => element.classList.add("is-visible"));
      else {
        const reveal = (entries: IntersectionObserverEntry[], observer: IntersectionObserver) => entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        });
        const observer = new IntersectionObserver(reveal, { threshold: 0.12 });
        const mobileItemObserver = new IntersectionObserver(reveal, { threshold: 1 });
        const mobile = window.matchMedia("(max-width: 900px)").matches;
        reveals.forEach((element) => {
          if (mobile && element.hasAttribute("data-mobile-reveal-items")) {
            [...element.children].forEach((item) => mobileItemObserver.observe(item));
          } else observer.observe(element);
        });
      }
    </script>
    {analyticsEnabled && analyticsToken && <script is:inline defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon={JSON.stringify({ token: analyticsToken })}></script>}
  </body>
</html>
