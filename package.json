{
  "name": "webpilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 127.0.0.1",
    "build": "astro build && node scripts/security-headers.mjs",
    "preview": "npm run build && wrangler dev",
    "lint": "eslint .",
    "check": "astro check && tsc -p tsconfig.worker.json --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test tests/e2e",
    "test:visual": "playwright test tests/visual-parity.spec.ts",
    "verify": "npm run lint && npm run check && npm test && npm run build",
    "studio": "sanity dev",
    "studio:deploy": "sanity deploy",
    "deploy": "npm run build && wrangler deploy",
    "cf:check": "wrangler deploy --dry-run --env=\"\""
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/playfair-display": "^5.3.0",
    "@lucide/astro": "^1.25.0",
    "@sanity/client": "^7.24.0",
    "astro": "7.1.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.11.0",
    "@cloudflare/workers-types": "5.20260719.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^24.0.0",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^3.0.1",
    "sanity": "^6.5.0",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.0",
    "wrangler": "4.112.0"
  }
}
