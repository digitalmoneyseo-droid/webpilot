{
  "name": "webpilot-studio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 127.0.0.1",
    "build": "npm run validate && astro build && node scripts/generate-deployment-files.mjs && node scripts/validate-output.mjs",
    "preview": "npm run build && wrangler dev --var PUBLIC_SITE_URL:http://127.0.0.1:8787",
    "lint": "eslint .",
    "typecheck": "astro check && tsc -p tsconfig.worker.json --noEmit",
    "validate": "node scripts/validate-config.mjs && astro sync && tsx scripts/validate-content.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test tests/e2e",
    "test:visual": "playwright test tests/visual-parity.spec.ts",
    "deploy": "npm run build && wrangler deploy",
    "cf:typegen": "wrangler types",
    "cf:check": "wrangler deploy --dry-run --env=\"\""
  },
  "dependencies": {
    "@fontsource/bebas-neue": "5.3.0",
    "@lucide/astro": "^1.25.0",
    "astro": "7.1.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.11.0",
    "@cloudflare/vitest-pool-workers": "0.18.6",
    "@cloudflare/workers-types": "5.20260719.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.0.0",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^3.0.1",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.0",
    "wrangler": "4.112.0"
  }
}
